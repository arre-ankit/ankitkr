---
import { SITE_CONFIG } from '../config';

const currentPath = Astro.url.pathname;
---

<nav class="border-b border-dashed border-brand-text/10 relative z-10">
  <div class="flex justify-center px-8">
    <div class="w-full max-w-4xl grid grid-cols-1 md:grid-cols-12 gap-8">
      <div class="md:col-span-8 px-8 py-6 flex items-center gap-6 text-sm">
        {SITE_CONFIG.nav.map((item) => (
          <a
            href={item.href}
            class={`transition-colors ${
              currentPath === item.href || currentPath.startsWith(item.href + '/')
                ? 'text-brand-text'
                : 'text-brand-text/60 hover:text-brand-text'
            }`}
          >
            {item.name}
          </a>
        ))}
      </div>
      <div class="md:col-span-4 py-6"></div>
    </div>
  </div>
</nav>
