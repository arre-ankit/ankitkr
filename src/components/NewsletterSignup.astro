---
---

<div class="border border-dashed border-brand-text/10 p-6">
  <div class="flex items-center gap-2 mb-4">
    <svg class="w-3 h-3 text-brand-accent2 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
    </svg>
    <span class="text-xs font-semibold text-brand-accent2 tracking-widest uppercase">Tool Call</span>
  </div>
  <p class="text-base font-semibold text-brand-text leading-snug mb-1">
    Newsletter about improving your coding workflows.
  </p>
  <p class="text-xs text-brand-text/50 leading-relaxed mb-5">
    Weekly newsletter about improving your coding workflows.
  </p>

  <form id="newsletter-form" class="space-y-2">
    <input
      type="email"
      name="email"
      required
      placeholder="your@email.com"
      class="newsletter-input w-full px-3 py-2 text-xs font-mono bg-transparent border border-dashed border-brand-text/15 text-brand-text placeholder:text-brand-text/25 focus:outline-none focus:border-brand-text/40 transition-colors"
    />
    <button
      type="submit"
      class="w-full py-2 text-[11px] font-mono font-semibold tracking-[0.15em] uppercase bg-brand-text text-[var(--bg-body)] hover:opacity-80 transition-opacity"
    >
      Subscribe
    </button>
  </form>
</div>

<style>
  .newsletter-input:-webkit-autofill,
  .newsletter-input:-webkit-autofill:hover,
  .newsletter-input:-webkit-autofill:focus {
    -webkit-box-shadow: 0 0 0 1000px var(--bg-body) inset !important;
    -webkit-text-fill-color: var(--text-primary) !important;
    caret-color: var(--text-primary);
  }
</style>

<script>
  const form = document.getElementById('newsletter-form') as HTMLFormElement;

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const email = (form.elements.namedItem('email') as HTMLInputElement).value;
    const url = `https://toolcall.substack.com/subscribe?email=${encodeURIComponent(email)}`;
    window.open(url, '_blank', 'noopener,noreferrer');
  });
</script>
