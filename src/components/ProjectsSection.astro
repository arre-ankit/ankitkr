---
import { projects } from '../data/projects';
---

<section id="projects">
  <div class="flex items-baseline justify-between mb-3">
    <h2 class="text-xl font-semibold">Projects</h2>
    <a href="/projects" class="font-pixel text-[10px] uppercase tracking-wide text-brand-text/40 hover:text-brand-text transition-colors">All →</a>
  </div>

  <div class="border-t border-solid border-brand-text/10">
    {projects.map((project, i) => (
      <div class="grid items-center gap-x-4 gap-y-1 border-b border-solid border-brand-text/10 py-3 sm:grid-cols-[11rem_1fr]">
        <div class="flex items-center gap-2 min-w-0">
          <div class="w-6 h-6 min-w-6 rounded overflow-hidden border border-solid border-brand-text/10 bg-brand-text/[0.05] shrink-0">
            {(project.logo || project.mediaUrl) ? (
              <img src={project.logo || project.mediaUrl} alt="" class="w-full h-full object-cover" loading="lazy" />
            ) : (
              <span class="w-full h-full flex items-center justify-center font-mono text-[8px] text-brand-text/20">{project.name[0]}</span>
            )}
          </div>
          <a
            href={`/projects/${project.slug}`}
            class="text-sm font-medium text-brand-text/80 hover:text-[#0D3EFF] dark:hover:text-[#FF5F1F] transition-colors truncate"
          >
            {project.name}
          </a>
        </div>
        <div class="flex items-center gap-2 min-w-0">
          <span class="text-xs text-brand-text/45 truncate min-w-0 leading-relaxed">{project.description}</span>
          <div class="flex items-center gap-1.5 shrink-0">
            {project.demo && (
              <a
                href={project.demo}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1 rounded-md border border-solid border-brand-text/15 px-1.5 py-0.5 font-mono text-[9px] text-brand-text/45 hover:text-[#0D3EFF] dark:hover:text-[#FF5F1F] hover:border-[#0D3EFF]/30 dark:hover:border-[#FF5F1F]/30 transition-colors"
              >
                <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
                Demo
              </a>
            )}
            <a
              href={project.link}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1 rounded-md border border-solid border-brand-text/15 px-1.5 py-0.5 font-mono text-[9px] text-brand-text/45 hover:text-[#0D3EFF] dark:hover:text-[#FF5F1F] hover:border-[#0D3EFF]/30 dark:hover:border-[#FF5F1F]/30 transition-colors"
            >
              <svg width="8" height="8" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
              Source
            </a>
          </div>
        </div>
      </div>
    ))}
  </div>
</section>
