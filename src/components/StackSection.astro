const GROUPS: { label: string; items: { name: string; href: string; icon?: string }[] }[] = [
  {
    label: 'Languages',
    items: [
      { name: 'TypeScript', href: 'https://www.typescriptlang.org', icon: 'typescript' },
      { name: 'JavaScript', href: 'https://developer.mozilla.org/en-US/docs/Web/JavaScript', icon: 'javascript' },
      { name: 'Python', href: 'https://www.python.org', icon: 'python' },
    ],
  },
  {
    label: 'Frontend',
    items: [
      { name: 'React', href: 'https://react.dev', icon: 'react' },
      { name: 'Next.js', href: 'https://nextjs.org', icon: 'nextjs' },
      { name: 'Tailwind CSS', href: 'https://tailwindcss.com', icon: 'tailwind' },
    ],
  },
  {
    label: 'Backend & Database',
    items: [
      { name: 'Node.js', href: 'https://nodejs.org', icon: 'nodejs' },
      { name: 'Express', href: 'https://expressjs.com' },
      { name: 'NestJS', href: 'https://nestjs.com' },
      { name: 'PostgreSQL', href: 'https://www.postgresql.org', icon: 'postgresql' },
      { name: 'MongoDB', href: 'https://www.mongodb.com', icon: 'mongodb' },
      { name: 'Supabase', href: 'https://supabase.com' },
    ],
  },
  {
    label: 'Tools & AI',
    items: [
      { name: 'Git', href: 'https://git-scm.com', icon: 'git' },
      { name: 'Docker', href: 'https://www.docker.com', icon: 'docker' },
      { name: 'Cloudflare', href: 'https://www.cloudflare.com' },
      { name: 'Cursor', href: 'https://cursor.com', icon: 'cursor' },
      { name: 'Claude', href: 'https://claude.ai', icon: 'claude' },
      { name: 'ChatGPT', href: 'https://chatgpt.com', icon: 'chatgpt' },
    ],
  },
];
---

<section id="stack">
  <h2 class="text-xl font-semibold mb-3">Stack</h2>

  <div class="border-t border-solid border-brand-text/10">
    {GROUPS.map((group, gi) => (
      <div class="grid items-start gap-y-2 border-b border-solid border-brand-text/10 py-4 sm:grid-cols-[11rem_1fr]">
        <div class="text-sm text-brand-text/50 font-mono">
          <span class="mr-1.5 text-brand-text/30 select-none" aria-hidden="true">{String(gi + 1).padStart(2, '0')}</span>
          {group.label}
        </div>
        <ul class="flex flex-wrap gap-1.5">
          {group.items.map((item) => (
            <li class="flex">
              <a
                href={item.href}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1.5 rounded-md border border-solid border-brand-text/15 bg-brand-text/[0.02] px-2 py-1 font-mono text-xs text-brand-text/70 hover:text-brand-text hover:border-brand-text/30 transition-colors [&_svg]:w-4 [&_svg]:h-4 [&_svg]:shrink-0 [&_svg]:text-brand-text/55"
              >
                {item.icon && <span class="contents" set:html={ICONS[item.icon]} />}
                {item.name}
              </a>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</section>
