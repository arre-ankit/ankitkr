---
// Interactive Typing Speed Game
---

<div class="relative border-t border-l border-r border-dashed border-brand-text/10 p-6 bg-brand-text/[0.01]">
  <div class="absolute top-0 left-0 w-3 h-3 border-l-2 border-t-2 border-brand-accent4"></div>

  <div class="flex items-center justify-between mb-4">
    <h3 class="text-xs font-semibold text-brand-text/60 tracking-widest uppercase flex items-center gap-2">
      <span class="w-1.5 h-1.5 bg-brand-accent4 rotate-45"></span>
      Typing Speed
    </h3>
    <div class="flex items-center gap-3">
      <button
        id="typing-reset"
        class="text-xs text-brand-text/50 hover:text-brand-text transition-colors border border-dashed border-brand-text/10 hover:border-brand-text/20 px-2 py-1"
      >
        Reset
      </button>
    </div>
  </div>

  <div class="flex justify-between gap-2">
   <span id="wpm-display" class="text-sm font-mono text-brand-accent4 font-bold">WPM: 0 wpm</span>
    <span id="accuracy-display" class="text-sm font-mono text-brand-accent5 font-bold">Accuracy: 100%</span>
  </div>

  <div
    id="display-text"
    class="p-4 bg-brand-text/[0.01] text-sm leading-relaxed font-mono mb-3 min-h-[100px] break-words"
  ></div>

  <input
    type="text"
    id="typing-input"
    placeholder="Start typing here..."
    class="w-full p-3 border border-dashed border-brand-text/10 bg-brand-text/[0.01] text-sm text-brand-text focus:border-brand-accent4 focus:outline-none transition-colors font-mono"
    spellcheck="false"
    autocomplete="off"
    autocorrect="off"
    autocapitalize="off"
  />
</div>

<script>
  const sampleTexts = [
    "the quick brown fox jumps over the lazy dog in a hurry to get to the park to play with the kids and have fun with the family",
    "building great software requires patience and practice to build great software that is easy to understand and use and is a joy to use",
    "write code that humans can read and understand with good documentation and easy to maintain and scale without breaking the code",
    "every expert was once a beginner who never gave up and kept practicing and learning new things and built great software that is easy to understand",
    "the best way to predict the future is to invent it and build it and build great software that is easy to understand and use and is a joy to work with",
    "debugging is being a detective in your own crime story and solving the mystery and building great software that is easy to understand and use and is a joy to work with",
    "good design is obvious and great design is transparent and easy to use and is a joy to work with you don't need to be a designer to design great software",
    "learning to code is learning to think in new ways and build new things and build great software that is easy to understand and use and is a joy to work with",
    "practice makes perfect but perfect practice makes better and better practice makes great and great practice makes great software that is easy to understand and use and is a joy to work with",
    "focus on progress not perfection in everything you do and keep moving forward and build great software that is easy to understand and use and is a joy to work with",
    "small steps every day lead to big changes over time and keep moving forward and build great software that is easy to understand and use and is a joy to work with",
    "the only way to do great work is to love what you do and keep building and learning new things and build great software that is easy to understand and use and is a joy to work with",
  ];
  const inputEl = document.getElementById('typing-input') as HTMLInputElement;
  const displayEl = document.getElementById('display-text');
  const wpmEl = document.getElementById('wpm-display');
  const accuracyEl = document.getElementById('accuracy-display');
  const statusEl = document.getElementById('typing-status');
  const resetBtn = document.getElementById('typing-reset');

  let currentText = '';
  let startTime: number | null = null;
  let timerInterval: number | null = null;
  let isGameActive = false;
  let usedTexts: string[] = [];

  function getNewText(): string {
    if (usedTexts.length === sampleTexts.length) {
      usedTexts = [];
    }

    const availableTexts = sampleTexts.filter(text => !usedTexts.includes(text));
    const newText = availableTexts[Math.floor(Math.random() * availableTexts.length)];
    usedTexts.push(newText);

    return newText;
  }

  function initGame() {
    currentText = getNewText();
    updateDisplay('');

    if (inputEl) {
      inputEl.value = '';
      inputEl.disabled = false;
      inputEl.focus();
    }
    if (wpmEl) wpmEl.textContent = '0 wpm';
    if (accuracyEl) accuracyEl.textContent = '100%';
    if (statusEl) statusEl.textContent = 'Start typing to begin...';

    isGameActive = false;
    startTime = null;

    if (timerInterval) {
      clearInterval(timerInterval);
      timerInterval = null;
    }
  }

  function startGame() {
    if (!isGameActive) {
      isGameActive = true;
      startTime = Date.now();
      if (statusEl) statusEl.textContent = 'Keep typing...';

      timerInterval = window.setInterval(() => {
        updateWpm();
      }, 100);
    }
  }

  function updateWpm() {
    if (!startTime || !inputEl) return;

    const elapsed = (Date.now() - startTime) / 1000;
    const elapsedMinutes = elapsed / 60;

    const typed = inputEl.value;
    const totalCharsTyped = typed.length;

    if (totalCharsTyped === 0 || elapsedMinutes === 0) {
      if (wpmEl) wpmEl.textContent = '0 wpm';
      return;
    }

    let errors = 0;
    for (let i = 0; i < typed.length; i++) {
      if (typed[i] !== currentText[i]) {
        errors++;
      }
    }

    const grossWpm = (totalCharsTyped / 5) / elapsedMinutes;
    const netWpm = grossWpm - (errors / elapsedMinutes);
    const finalWpm = Math.max(0, Math.round(netWpm));

    if (wpmEl) wpmEl.textContent = `${finalWpm} wpm`;
  }

  function calculateAccuracy(typed: string): number {
    if (typed.length === 0) return 100;

    let correct = 0;
    for (let i = 0; i < typed.length; i++) {
      if (typed[i] === currentText[i]) {
        correct++;
      }
    }

    return Math.round((correct / typed.length) * 100);
  }

  function updateDisplay(typed: string) {
    if (!displayEl) return;

    let html = '';
    const targetChars = currentText.split('');
    const typedChars = typed.split('');

    for (let i = 0; i < targetChars.length; i++) {
      const targetChar = targetChars[i];

      if (i < typedChars.length) {
        const typedChar = typedChars[i];
        if (typedChar === targetChar) {
          html += `<span class="text-brand-accent4">${targetChar === ' ' ? '&nbsp;' : targetChar}</span>`;
        } else {
          html += `<span class="text-red-500 bg-red-500/10">${targetChar === ' ' ? '&nbsp;' : targetChar}</span>`;
        }
      } else if (i === typedChars.length) {
        html += `<span class="text-brand-text/40 bg-brand-accent4/10">${targetChar === ' ' ? '&nbsp;' : targetChar}</span>`;
      } else {
        html += `<span class="text-brand-text/30">${targetChar === ' ' ? '&nbsp;' : targetChar}</span>`;
      }
    }

    displayEl.innerHTML = html;

    if (typed.length >= currentText.length) {
      endGame(typed);
    }
  }

  function endGame(typed: string) {
    isGameActive = false;
    if (timerInterval) {
      clearInterval(timerInterval);
      timerInterval = null;
    }

    if (inputEl) {
      inputEl.disabled = true;
    }

    const accuracy = calculateAccuracy(typed);
    if (accuracyEl) accuracyEl.textContent = `${accuracy}%`;
  }

  function handleInput() {
    if (!inputEl) return;

    let typed = inputEl.value;

    if (typed.length > currentText.length) {
      typed = typed.substring(0, currentText.length);
      inputEl.value = typed;
    }

    if (!isGameActive && typed.length > 0) {
      startGame();
    }

    if (isGameActive) {
      updateWpm();
      const accuracy = calculateAccuracy(typed);
      if (accuracyEl) accuracyEl.textContent = `${accuracy}%`;
    }

    updateDisplay(typed);
  }

  inputEl?.addEventListener('input', handleInput);
  resetBtn?.addEventListener('click', () => {
    initGame();
  });

  initGame();
</script>
