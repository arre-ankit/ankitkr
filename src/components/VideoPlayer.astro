---
interface Props {
  videoUrl: string;
  title: string;
}

const { videoUrl, title } = Astro.props;

// Convert YouTube watch URL to embed URL
function getEmbedUrl(url: string): string {
  if (url.includes('youtube.com/watch?v=')) {
    const videoId = url.split('v=')[1]?.split('&')[0];
    return `https://www.youtube.com/embed/${videoId}`;
  }
  if (url.includes('youtu.be/')) {
    const videoId = url.split('youtu.be/')[1]?.split('?')[0];
    return `https://www.youtube.com/embed/${videoId}`;
  }
  if (url.includes('youtube.com/embed/')) {
    return url;
  }
  return url;
}

const embedUrl = getEmbedUrl(videoUrl);
---

<!-- Creative Video Grid Component -->
<div class="relative">
  <!-- Outer corner accents -->
  <div class="absolute -top-2 -left-2 w-4 h-4 border-l-2 border-t-2 border-brand-accent2"></div>
  <div class="absolute -top-2 -right-2 w-4 h-4 border-r-2 border-t-2 border-brand-accent3"></div>
  <div class="absolute -bottom-2 -left-2 w-4 h-4 border-l-2 border-b-2 border-brand-accent4"></div>
  <div class="absolute -bottom-2 -right-2 w-4 h-4 border-r-2 border-b-2 border-brand-accent5"></div>

  <div class="relative border-2 border-dashed border-brand-text/10 p-1 bg-gradient-to-br from-brand-text/[0.01] to-brand-text/[0.02]">
    <!-- Animated corner dots -->
    <div class="absolute top-3 left-3 flex gap-1 z-10">
      <div class="w-1 h-1 bg-brand-accent2 rotate-45 animate-pulse"></div>
      <div class="w-1 h-1 bg-brand-accent3 rotate-45 animate-pulse" style="animation-delay: 0.2s"></div>
    </div>
    <div class="absolute top-3 right-3 flex gap-1 z-10">
      <div class="w-1 h-1 bg-brand-accent3 rotate-45 animate-pulse" style="animation-delay: 0.3s"></div>
      <div class="w-1 h-1 bg-brand-accent4 rotate-45 animate-pulse" style="animation-delay: 0.5s"></div>
    </div>
    <div class="absolute bottom-3 left-3 flex gap-1 z-10">
      <div class="w-1 h-1 bg-brand-accent4 rotate-45 animate-pulse" style="animation-delay: 0.4s"></div>
      <div class="w-1 h-1 bg-brand-accent5 rotate-45 animate-pulse" style="animation-delay: 0.6s"></div>
    </div>
    <div class="absolute bottom-3 right-3 flex gap-1 z-10">
      <div class="w-1 h-1 bg-brand-accent5 rotate-45 animate-pulse" style="animation-delay: 0.7s"></div>
      <div class="w-1 h-1 bg-brand-accent2 rotate-45 animate-pulse" style="animation-delay: 0.8s"></div>
    </div>

    <!-- Video player with grid border -->
    <div class="relative aspect-video border border-dashed border-brand-text/20 bg-black overflow-hidden">
      <iframe
        src={embedUrl}
        title={title}
        class="absolute inset-0 w-full h-full"
        frameborder="0"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
        allowfullscreen
      ></iframe>

      <!-- Decorative grid overlay corners -->
      <div class="absolute top-0 left-0 w-12 h-12 border-l-2 border-t-2 border-brand-accent2/40 pointer-events-none"></div>
      <div class="absolute top-0 right-0 w-12 h-12 border-r-2 border-t-2 border-brand-accent3/40 pointer-events-none"></div>
      <div class="absolute bottom-0 left-0 w-12 h-12 border-l-2 border-b-2 border-brand-accent4/40 pointer-events-none"></div>
      <div class="absolute bottom-0 right-0 w-12 h-12 border-r-2 border-b-2 border-brand-accent5/40 pointer-events-none"></div>

      <!-- Inner corner accents -->
      <div class="absolute top-2 left-2 w-6 h-6 border-l border-t border-dashed border-brand-accent2/30 pointer-events-none"></div>
      <div class="absolute top-2 right-2 w-6 h-6 border-r border-t border-dashed border-brand-accent3/30 pointer-events-none"></div>
      <div class="absolute bottom-2 left-2 w-6 h-6 border-l border-b border-dashed border-brand-accent4/30 pointer-events-none"></div>
      <div class="absolute bottom-2 right-2 w-6 h-6 border-r border-b border-dashed border-brand-accent5/30 pointer-events-none"></div>
    </div>

    <!-- Video caption with grid accent -->
    <div class="mt-3 flex items-center gap-2 px-2">
      <span class="w-1 h-4 bg-gradient-to-b from-brand-accent2 to-brand-accent3"></span>
      <p class="text-xs font-mono text-brand-text/60 tracking-wide">Project Demo</p>
      <div class="flex gap-1 ml-auto">
        <div class="w-0.5 h-0.5 bg-brand-text/30 rotate-45"></div>
        <div class="w-0.5 h-0.5 bg-brand-text/30 rotate-45"></div>
        <div class="w-0.5 h-0.5 bg-brand-text/30 rotate-45"></div>
      </div>
    </div>
  </div>
</div>

<style>
  /* Ensure video is responsive and fills container */
  iframe {
    display: block;
  }
</style>
