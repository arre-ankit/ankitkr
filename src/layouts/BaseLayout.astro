---
import '../styles/global.css';
import BaseHead from '../components/BaseHead.astro';
import ScrollProgress from '../components/ScrollProgress.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  schema?: object;
  wide?: boolean;
  reader?: boolean;
}

const { title, description, image, schema, wide = false, reader = false } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} image={image} schema={schema} />
    <script is:inline>
      (function() {
        var theme = localStorage.getItem('theme');
        if (theme === 'dark') {
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>
  <body class="min-h-screen relative">
    {!reader && <ScrollProgress />}
    {!wide && !reader && (
      <>
        <!-- Grid System Overlay - Fixed positioned grid lines -->
        <div class="fixed top-0 bottom-0 w-px border-l border-solid border-brand-text/10 pointer-events-none z-0" style="left: calc(50% - min(100vw / 2 - 2rem, 28rem));"></div>
        <div class="fixed top-0 bottom-0 w-px border-r border-solid border-brand-text/10 pointer-events-none z-0" style="right: calc(50% - min(100vw / 2 - 2rem, 32rem));"></div>
      </>
    )}
    {reader ? (
      <main class="relative z-10 px-5 sm:px-8 pt-0 pb-12 lg:pt-12 lg:pb-0 lg:h-screen lg:overflow-hidden">
        <div class="w-full max-w-[88rem] mx-auto lg:h-full lg:flex lg:flex-col">
          <slot />
        </div>
      </main>
    ) : (
      <main class="flex justify-center px-5 sm:px-8 py-8 sm:py-12 relative z-10">
        <div class={wide ? 'w-full max-w-[88rem]' : 'w-full max-w-4xl'}>
          <slot />
        </div>
      </main>
    )}
  </body>
</html>
