---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_CONFIG } from '../config';
---

<BaseLayout title="404 - Page Not Found" description="This page doesn't exist">
  <div class="flex justify-center px-5 sm:px-8 py-12 sm:py-16">
    <div class="w-full max-w-4xl grid grid-cols-1 md:grid-cols-12 gap-8">
      <!-- Main Content - Centered Error Message -->
      <div class="md:col-span-8 space-y-8 border-l border-r border-solid border-brand-text/10 px-5 sm:px-8 pb-12 pt-0">
        <!-- Large 404 with Corner Accents -->
        <div class="relative">
          <div class="absolute top-0 left-0 w-4 h-4 border-l-2 border-t-2 border-brand-accent2"></div>
          <div class="absolute top-0 right-0 w-4 h-4 border-r-2 border-t-2 border-brand-accent3"></div>
          <div class="absolute bottom-0 left-0 w-4 h-4 border-l-2 border-b-2 border-brand-accent4"></div>
          <div class="absolute bottom-0 right-0 w-4 h-4 border-r-2 border-b-2 border-brand-accent5"></div>

          <div class="text-center py-12">
            <h1 class="text-9xl font-bold text-brand-text/10 tracking-tighter font-mono">404</h1>
            <div class="absolute inset-0 flex items-center justify-center">
              <div class="grid grid-cols-3 gap-1">
                <div class="w-2 h-2 bg-brand-accent2 rotate-45 animate-pulse"></div>
                <div class="w-2 h-2 bg-brand-accent3 rotate-45 animate-pulse" style="animation-delay: 0.1s"></div>
                <div class="w-2 h-2 bg-brand-accent4 rotate-45 animate-pulse" style="animation-delay: 0.2s"></div>
                <div class="w-2 h-2 bg-brand-accent5 rotate-45 animate-pulse" style="animation-delay: 0.3s"></div>
                <div class="w-2 h-2 bg-brand-accent2 rotate-45 animate-pulse" style="animation-delay: 0.4s"></div>
                <div class="w-2 h-2 bg-brand-accent3 rotate-45 animate-pulse" style="animation-delay: 0.5s"></div>
                <div class="w-2 h-2 bg-brand-accent4 rotate-45 animate-pulse" style="animation-delay: 0.6s"></div>
                <div class="w-2 h-2 bg-brand-accent5 rotate-45 animate-pulse" style="animation-delay: 0.7s"></div>
                <div class="w-2 h-2 bg-brand-accent2 rotate-45 animate-pulse" style="animation-delay: 0.8s"></div>
              </div>
            </div>
          </div>
        </div>

        <!-- Error Message -->
        <div class="text-center space-y-4 relative">
          <h2 class="text-3xl font-semibold text-brand-text">Page Not Found</h2>
          <p class="text-brand-text/70 leading-relaxed max-w-md mx-auto">
            The page you're looking for doesn't exist. It might have been moved, deleted, or perhaps it never existed in the first place.
          </p>
        </div>

        <!-- Navigation Options -->
        <div class="space-y-4">
          <p class="text-sm text-brand-text/60 text-center">Here are some helpful links instead:</p>
          <div class="grid grid-cols-2 gap-3">
            <a href="/" class="group flex items-center justify-between p-4 border border-solid border-brand-text/10 hover:border-brand-accent2 bg-brand-text/[0.01] hover:bg-brand-text/[0.02] transition-all">
              <span class="text-sm text-brand-text/70 group-hover:text-brand-text transition-colors">Home</span>
              <svg class="w-4 h-4 text-brand-text/40 group-hover:text-brand-accent2 group-hover:translate-x-1 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </a>

            <a href="/writing" class="group flex items-center justify-between p-4 border border-solid border-brand-text/10 hover:border-brand-accent3 bg-brand-text/[0.01] hover:bg-brand-text/[0.02] transition-all">
              <span class="text-sm text-brand-text/70 group-hover:text-brand-text transition-colors">Writing</span>
              <svg class="w-4 h-4 text-brand-text/40 group-hover:text-brand-accent3 group-hover:translate-x-1 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </a>

            <a href="/projects" class="group flex items-center justify-between p-4 border border-solid border-brand-text/10 hover:border-brand-accent4 bg-brand-text/[0.01] hover:bg-brand-text/[0.02] transition-all">
              <span class="text-sm text-brand-text/70 group-hover:text-brand-text transition-colors">Projects</span>
              <svg class="w-4 h-4 text-brand-text/40 group-hover:text-brand-accent4 group-hover:translate-x-1 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </a>
          </div>
        </div>
      </div>

      <!-- Creative Sidebar -->
      <div class="md:col-span-4 space-y-0 pt-0">
        <!-- Error Code Info -->
        <div class="relative border-t border-l border-r border-solid border-brand-text/10 p-6 bg-brand-text/[0.01]">
          <div class="absolute top-0 left-0 w-3 h-3 border-l-2 border-t-2 border-brand-accent3"></div>

          <h3 class="text-xs font-semibold text-brand-text/60 mb-4 tracking-widest uppercase flex items-center gap-2">
            <span class="w-1.5 h-1.5 bg-brand-accent3 rotate-45"></span>
            Error Details
          </h3>

          <div class="space-y-3 text-sm">
            <div class="flex items-center justify-between p-3 border border-solid border-brand-text/10 bg-brand-text/[0.01]">
              <span class="text-brand-text/70">Status Code</span>
              <span class="font-mono text-xs text-brand-text/60">404</span>
            </div>

            <div class="flex items-center justify-between p-3 border border-solid border-brand-text/10 bg-brand-text/[0.01]">
              <span class="text-brand-text/70">Error Type</span>
              <span class="font-mono text-xs text-brand-text/60">Not Found</span>
            </div>
          </div>
        </div>

        <!-- Fun Fact -->
        <div class="relative border-t border-l border-r border-solid border-brand-text/10 p-6 bg-brand-text/[0.01]">
          <h3 class="text-xs font-semibold text-brand-text/60 mb-4 tracking-widest uppercase flex items-center gap-2">
            <span class="w-1.5 h-1.5 bg-brand-accent2 rotate-45"></span>
            Fun Fact
          </h3>

          <div class="space-y-3 text-xs text-brand-text/70 leading-relaxed">
            <div class="flex items-start gap-2 p-3 border border-solid border-brand-text/10 bg-brand-text/[0.01]">
              <span class="text-brand-accent2 mt-0.5">▸</span>
              <p>404 is the HTTP status code for "Not Found"</p>
            </div>
            <div class="flex items-start gap-2 p-3 border border-solid border-brand-text/10 bg-brand-text/[0.01]">
              <span class="text-brand-accent2 mt-0.5">▸</span>
              <p>The error code originates from room 404 at CERN</p>
            </div>
            <div class="flex items-start gap-2 p-3 border border-solid border-brand-text/10 bg-brand-text/[0.01]">
              <span class="text-brand-accent2 mt-0.5">▸</span>
              <p>It's one of the most well-known error messages</p>
            </div>
          </div>
        </div>

        <!-- Help -->
        <div class="relative border border-solid border-brand-text/10 p-6 bg-brand-text/[0.01] group hover:bg-brand-text/[0.03] transition-all">
          <div class="absolute bottom-0 right-0 w-3 h-3 border-r-2 border-b-2 border-brand-accent5"></div>

          <h3 class="text-xs font-semibold text-brand-text/60 mb-3 tracking-widest uppercase">Need Help?</h3>

          <p class="text-sm text-brand-text/70 leading-relaxed mb-4">
            If you think this is a mistake, feel free to reach out.
          </p>

          <a href={`mailto:${SITE_CONFIG.author.email}`} class="inline-flex items-center gap-2 text-sm font-medium text-brand-text hover:text-brand-accent3 transition-colors border-b border-solid border-brand-text/20 hover:border-brand-accent3 pb-0.5">
            Contact me
            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
