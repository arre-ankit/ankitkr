---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_CONFIG } from '../config';
---

<BaseLayout title="About" description="Learn more about me">
  <div class="grid grid-cols-1 md:grid-cols-12 gap-8">
    <!-- Main Content - Centered -->
    <div class="md:col-span-8 space-y-8 px-8 pb-12 pt-0">
      <h1 class="text-4xl font-semibold text-brand-text tracking-tight">About</h1>

      <div class="prose space-y-6 text-brand-text/90 leading-relaxed">
        <p class="text-lg">
          Hi, I'm {SITE_CONFIG.name}. This is my personal corner of the internet where I share my
          thoughts, writing, and projects.
        </p>

        <p>
          I'm passionate about technology, design, and creating thoughtful digital experiences.
          This website is a place for me to document my journey, share what I'm learning, and
          connect with others who share similar interests.
        </p>

        <div class="pt-4">
          <h2 class="text-xl font-semibold mb-4 flex items-center gap-2">
            <span class="w-1 h-6 bg-brand-accent2"></span>
            What I Do
          </h2>
          <p>
            I spend my time building things, writing about what I learn, and exploring new ideas.
            My work spans across web development, design, and various creative projects.
          </p>
        </div>

        <div class="pt-4">
          <h2 class="text-xl font-semibold mb-4 flex items-center gap-2">
            <span class="w-1 h-6 bg-brand-accent3"></span>
            Get in Touch
          </h2>
          <p>
            I'm always happy to connect with interesting people. Feel free to reach out if you'd
            like to chat about technology, collaborate on a project, or just say hello.
          </p>

          <div class="flex flex-wrap gap-3 mt-6 pl-4 border-l-2 border-dashed border-brand-text/20">
            {SITE_CONFIG.author.email && (
              <a
                href={`mailto:${SITE_CONFIG.author.email}`}
                class="px-4 py-2 border border-dashed border-brand-text/20 hover:border-brand-accent3 bg-brand-text/[0.01] hover:bg-brand-text/[0.02] transition-all text-sm"
              >
                Email
              </a>
            )}
            {SITE_CONFIG.author.twitter && (
              <a
                href={`https://twitter.com/${SITE_CONFIG.author.twitter.replace('@', '')}`}
                target="_blank"
                rel="noopener noreferrer"
                class="px-4 py-2 border border-dashed border-brand-text/20 hover:border-brand-accent2 bg-brand-text/[0.01] hover:bg-brand-text/[0.02] transition-all text-sm"
              >
                Twitter
              </a>
            )}
            {SITE_CONFIG.author.github && (
              <a
                href={`https://github.com/${SITE_CONFIG.author.github}`}
                target="_blank"
                rel="noopener noreferrer"
                class="px-4 py-2 border border-dashed border-brand-text/20 hover:border-brand-accent4 bg-brand-text/[0.01] hover:bg-brand-text/[0.02] transition-all text-sm"
              >
                GitHub
              </a>
            )}
            {SITE_CONFIG.author.linkedin && (
              <a
                href={`https://linkedin.com/in/${SITE_CONFIG.author.linkedin}`}
                target="_blank"
                rel="noopener noreferrer"
                class="px-4 py-2 border border-dashed border-brand-text/20 hover:border-brand-accent5 bg-brand-text/[0.01] hover:bg-brand-text/[0.02] transition-all text-sm"
              >
                LinkedIn
              </a>
            )}
          </div>
        </div>
      </div>
    </div>

    <!-- Creative Sidebar -->
    <div class="md:col-span-4 space-y-0 pt-0">
      <!-- Currently Status Card -->
      <div class="relative border-t border-l border-r border-dashed border-brand-text/10 p-6 bg-brand-text/[0.01]">
        <div class="absolute top-0 left-0 w-3 h-3 border-l-2 border-t-2 border-brand-accent3"></div>

        <div class="flex items-center gap-2 mb-4">
          <div class="flex gap-1.5">
            <div class="w-2 h-2 rounded-full bg-brand-accent3 animate-pulse"></div>
            <div class="w-2 h-2 rounded-full bg-brand-accent3/60"></div>
            <div class="w-2 h-2 rounded-full bg-brand-accent3/30"></div>
          </div>
          <span class="text-xs text-brand-text/60 font-medium uppercase tracking-wider">Currently</span>
        </div>

        <p class="text-sm text-brand-text/70 leading-relaxed mb-1">
          Full Stack Developer
        </p>
        <p class="text-sm text-brand-text/50">
          @ <a href="https://langbase.com" target="_blank" rel="noopener noreferrer" class="underline underline-offset-4 decoration-brand-text/40 hover:decoration-brand-text transition-colors">Langbase</a> <br />
          <div class="text-xs text-brand-text/50 mt-1">shipping the future of ai agents</div>
        </p>
      </div>

      <!-- Quick Facts Grid -->
      <div class="relative border-t border-l border-r border-dashed border-brand-text/10 p-6 bg-brand-text/[0.01]">
        <h3 class="text-xs font-semibold text-brand-text/60 mb-4 tracking-widest uppercase flex items-center gap-2">
          <span class="w-1.5 h-1.5 bg-brand-accent2 rotate-45"></span>
          Quick Facts
        </h3>

        <div class="grid grid-cols-2 gap-3">
          <div class="border border-dashed border-brand-text/10 p-3 bg-brand-text/[0.01] hover:bg-brand-text/[0.02] transition-all group">
            <div class="text-2xl mb-2 group-hover:scale-110 transition-transform">🤔</div>
            <p class="text-xs text-brand-text/60">Curious</p>
          </div>

          <div class="border border-dashed border-brand-text/10 p-3 bg-brand-text/[0.01] hover:bg-brand-text/[0.02] transition-all group">
            <div class="text-2xl mb-2 group-hover:scale-110 transition-transform">🧑‍💻</div>
            <p class="text-xs text-brand-text/60">Coder</p>
          </div>

          <div class="border border-dashed border-brand-text/10 p-3 bg-brand-text/[0.01] hover:bg-brand-text/[0.02] transition-all group">
            <div class="text-2xl mb-2 group-hover:scale-110 transition-transform">📷</div>
            <p class="text-xs text-brand-text/60">Photographer</p>
          </div>

          <div class="border border-dashed border-brand-text/10 p-3 bg-brand-text/[0.01] hover:bg-brand-text/[0.02] transition-all group">
            <div class="text-2xl mb-2 group-hover:scale-110 transition-transform">🌌</div>
            <p class="text-xs text-brand-text/60">Astro</p>
          </div>
        </div>
      </div>

      <!-- Currently Reading -->
      <div class="relative border-t border-l border-r border-dashed border-brand-text/10 p-6 bg-brand-text/[0.01]">
        <h3 class="text-xs font-semibold text-brand-text/60 mb-4 tracking-widest uppercase flex items-center gap-2">
          <span class="w-1.5 h-1.5 bg-brand-accent4 rotate-45"></span>
          Currently Reading
        </h3>

        <div class="space-y-3">
          <div class="pl-4 border-l-2 border-dashed border-brand-text/10">
            <p class="text-sm text-brand-text/80 font-medium mb-1">The Design of Everyday Things</p>
            <p class="text-xs text-brand-text/50">by Don Norman</p>
          </div>
        </div>
      </div>

      <!-- Skills & Interests -->
      <div class="relative border border-dashed border-brand-text/10 p-6 bg-brand-text/[0.01]">
        <div class="absolute bottom-0 right-0 w-3 h-3 border-r-2 border-b-2 border-brand-accent5"></div>

        <h3 class="text-xs font-semibold text-brand-text/60 mb-4 tracking-widest uppercase flex items-center gap-2">
          <span class="w-1.5 h-1.5 bg-brand-accent5 rotate-45"></span>
          Interests
        </h3>

        <div class="flex flex-wrap gap-2">
          <span class="px-3 py-1.5 border border-dashed border-brand-text/10 bg-brand-text/[0.01] text-xs text-brand-text/70">
            Web Dev
          </span>
          <span class="px-3 py-1.5 border border-dashed border-brand-text/10 bg-brand-text/[0.01] text-xs text-brand-text/70">
            Design
          </span>
          <span class="px-3 py-1.5 border border-dashed border-brand-text/10 bg-brand-text/[0.01] text-xs text-brand-text/70">
            Writing
          </span>
          <span class="px-3 py-1.5 border border-dashed border-brand-text/10 bg-brand-text/[0.01] text-xs text-brand-text/70">
            AI/ML
          </span>
          <span class="px-3 py-1.5 border border-dashed border-brand-text/10 bg-brand-text/[0.01] text-xs text-brand-text/70">
            Open Source
          </span>
        </div>

        
      </div>
    </div>
  </div>
</BaseLayout>
