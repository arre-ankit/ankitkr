---
import BaseLayout from '../layouts/BaseLayout.astro';
import TicTacToe from '../components/TicTacToe.astro';
import { SITE_CONFIG } from '../config';
---

<BaseLayout>
  <div class="grid grid-cols-1 md:grid-cols-12 gap-8">
    <!-- Main Content - The Meat -->
    <div class="md:col-span-8 space-y-8 border-brand-text/10 px-8 pb-12 pt-0">
      <h1 class="text-4xl font-semibold text-brand-text tracking-tight">
        {SITE_CONFIG.name}
      </h1>
      <div class="space-y-4 text-brand-text/90 leading-relaxed">
        <p>
          I'm a developer and writer. I work at <a href="https://langbase.com" class="underline underline-offset-4 decoration-brand-text/40 hover:decoration-brand-text transition-colors">⌘ Langbase</a> teaching about technology. Previously, I worked at <a href="https://www.pathaka.ai/" class="underline underline-offset-4 decoration-brand-text/40 hover:decoration-brand-text transition-colors">Pathaka</a>. I've been coding for 3 years and teaching for the second half.
        </p>
        <p>
          My life's work is to make technology easy to understand and interesting to learn about. I'm a husband, father, and a massive music fan. I last listened to <a href="#" class="underline underline-offset-4 decoration-brand-text/40 hover:decoration-brand-text transition-colors">Song Title - Artist</a>.
        </p>
        <div class="pt-4">
          <p class="mb-3 text-brand-text/60 text-sm font-medium tracking-wide uppercase">Featured Essays</p>
          <ul class="space-y-2 ml-6 border-l border-dashed border-brand-text/20 pl-4">
            <li>
              <a href="/writing" class="underline underline-offset-4 decoration-brand-text/40 hover:decoration-brand-text transition-colors">Things I Believe</a>
            </li>
            <li>
              <a href="/writing" class="underline underline-offset-4 decoration-brand-text/40 hover:decoration-brand-text transition-colors">Developer Experience</a>
            </li>
            <li>
              <a href="/writing" class="underline underline-offset-4 decoration-brand-text/40 hover:decoration-brand-text transition-colors">Developer Relations</a>
            </li>
            <li>
              <a href="/writing" class="underline underline-offset-4 decoration-brand-text/40 hover:decoration-brand-text transition-colors">Developer Products</a>
            </li>
            <li>
              <a href="/writing" class="underline underline-offset-4 decoration-brand-text/40 hover:decoration-brand-text transition-colors">Developer Marketing</a>
            </li>
            <li>
              <a href="/writing" class="underline underline-offset-4 decoration-brand-text/40 hover:decoration-brand-text transition-colors">Documentation</a>
            </li>
          </ul>
        </div>

        <p class="pt-4">
          You can read <a href="/writing" class="underline underline-offset-4 decoration-brand-text/40 hover:decoration-brand-text transition-colors">my writing</a> or code, or <a href="#" class="underline underline-offset-4 decoration-brand-text/40 hover:decoration-brand-text transition-colors">follow me online</a>. I also make <a href="#" class="underline underline-offset-4 decoration-brand-text/40 hover:decoration-brand-text transition-colors">videos</a>, advise companies, and do angel investing. Reach out if interested.
        </p>
      </div>
    </div>

    <!-- Sidebar - Creative Grid Layout -->
    <div class="md:col-span-4 space-y-0 pt-0">

      <!-- Tic-Tac-Toe Game -->
      <TicTacToe />

      <!-- Social Connect with Dashed Grid -->
      <div class="relative border-t border-l border-r border-dashed border-brand-text/10 p-6 bg-brand-text/[0.01]">
        <h3 class="text-xs font-semibold text-brand-text/60 mb-4 tracking-widest uppercase flex items-center gap-2">
          <span class="w-1.5 h-1.5 bg-brand-accent2 rotate-45"></span>
          Connect
        </h3>

        <div class="space-y-2">
          <a href="https://twitter.com/arre_ankit" class="group flex items-center justify-between p-3 border border-dashed border-brand-text/10 hover:border-brand-text/20 bg-brand-text/[0.01] hover:bg-brand-text/[0.02] transition-all">
            <span class="text-sm text-brand-text/70 group-hover:text-brand-text transition-colors">Twitter</span>
            <svg class="w-4 h-4 text-brand-text/40 group-hover:text-brand-text/70 transition-colors" fill="currentColor" viewBox="0 0 24 24">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>

          <a href="https://github.com/yourusername" class="group flex items-center justify-between p-3 border border-dashed border-brand-text/10 hover:border-brand-text/20 bg-brand-text/[0.01] hover:bg-brand-text/[0.02] transition-all">
            <span class="text-sm text-brand-text/70 group-hover:text-brand-text transition-colors">GitHub</span>
            <svg class="w-4 h-4 text-brand-text/40 group-hover:text-brand-text/70 transition-colors" fill="currentColor" viewBox="0 0 24 24">
              <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/>
            </svg>
          </a>

          <a href="https://linkedin.com/in/yourusername" class="group flex items-center justify-between p-3 border border-dashed border-brand-text/10 hover:border-brand-text/20 bg-brand-text/[0.01] hover:bg-brand-text/[0.02] transition-all">
            <span class="text-sm text-brand-text/70 group-hover:text-brand-text transition-colors">LinkedIn</span>
            <svg class="w-4 h-4 text-brand-text/40 group-hover:text-brand-text/70 transition-colors" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Latest Activity -->
      <div class="relative border border-dashed border-brand-text/10 p-6 bg-brand-text/[0.01]">
        <div class="absolute bottom-0 right-0 w-3 h-3 border-r-2 border-b-2 border-brand-accent5"></div>

        <h3 class="text-xs font-semibold text-brand-text/60 mb-4 tracking-widest uppercase flex items-center gap-2">
          <span class="w-1.5 h-1.5 bg-brand-accent5 rotate-45"></span>
          Latest
        </h3>

        <div class="space-y-4">
          <div class="group relative pl-4 border-l-2 border-dashed border-brand-text/10">
            <p class="text-xs text-brand-text/50 mb-1.5 font-mono">2 days ago</p>
            <a href="/writing" class="text-sm text-brand-text/80 hover:text-brand-text leading-snug block transition-colors">
              New essay: Building better developer experiences
            </a>
          </div>

          <div class="h-px border-t border-dashed border-brand-text/10"></div>

          <div class="group relative pl-4 border-l-2 border-dashed border-brand-text/10">
            <p class="text-xs text-brand-text/50 mb-1.5 font-mono">1 week ago</p>
            <a href="/projects" class="text-sm text-brand-text/80 hover:text-brand-text leading-snug block transition-colors">
              Launched new project: AI writing assistant
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
