---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_CONFIG } from '../config';
---

<BaseLayout>
  <div class="space-y-12 md:space-y-16">
    <section class="space-y-6">
      <h1 class="text-5xl md:text-6xl font-bold text-gray-900 dark:text-gray-100 tracking-tight">
        {SITE_CONFIG.name}
      </h1>
      <p class="text-xl md:text-2xl text-gray-600 dark:text-gray-400 leading-relaxed max-w-2xl">
        Welcome to my digital home. I write about technology, design, and the things I'm learning
        along the way.
      </p>
      <div class="flex flex-wrap gap-4 pt-4">
        <a
          href="/blog"
          class="px-6 py-3 rounded-lg bg-gray-900 dark:bg-gray-100 text-white dark:text-gray-900 font-medium hover:bg-gray-700 dark:hover:bg-gray-300 transition-colors"
        >
          Read my blog
        </a>
        <a
          href="/about"
          class="px-6 py-3 rounded-lg border border-gray-300 dark:border-gray-700 text-gray-900 dark:text-gray-100 font-medium hover:border-gray-400 dark:hover:border-gray-600 transition-colors"
        >
          About me
        </a>
      </div>
    </section>

    <section class="space-y-6 pt-8 border-t border-gray-200 dark:border-gray-800">
      <h2 class="text-2xl md:text-3xl font-semibold text-gray-900 dark:text-gray-100">
        What I'm up to
      </h2>
      <div class="grid md:grid-cols-2 gap-6">
        <a href="/blog" class="group space-y-2 p-6 rounded-lg border border-gray-200 dark:border-gray-800 hover:border-gray-300 dark:hover:border-gray-700 transition-colors">
          <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 group-hover:text-gray-600 dark:group-hover:text-gray-400 transition-colors">
            Blog
          </h3>
          <p class="text-gray-600 dark:text-gray-400">
            Short posts about what I'm thinking, building, and discovering
          </p>
        </a>
        <a href="/writing" class="group space-y-2 p-6 rounded-lg border border-gray-200 dark:border-gray-800 hover:border-gray-300 dark:hover:border-gray-700 transition-colors">
          <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 group-hover:text-gray-600 dark:group-hover:text-gray-400 transition-colors">
            Writing
          </h3>
          <p class="text-gray-600 dark:text-gray-400">
            Long-form essays and deeper thoughts on topics I care about
          </p>
        </a>
        <a href="/projects" class="group space-y-2 p-6 rounded-lg border border-gray-200 dark:border-gray-800 hover:border-gray-300 dark:hover:border-gray-700 transition-colors">
          <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 group-hover:text-gray-600 dark:group-hover:text-gray-400 transition-colors">
            Projects
          </h3>
          <p class="text-gray-600 dark:text-gray-400">
            Side projects, experiments, and things I've built
          </p>
        </a>
        <a href="/about" class="group space-y-2 p-6 rounded-lg border border-gray-200 dark:border-gray-800 hover:border-gray-300 dark:hover:border-gray-700 transition-colors">
          <h3 class="text-lg font-semibold text-gray-900 dark:text-gray-100 group-hover:text-gray-600 dark:group-hover:text-gray-400 transition-colors">
            About
          </h3>
          <p class="text-gray-600 dark:text-gray-400">
            Learn more about who I am and what I do
          </p>
        </a>
      </div>
    </section>
  </div>
</BaseLayout>
