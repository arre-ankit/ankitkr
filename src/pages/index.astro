---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import TicTacToe from '../components/TicTacToe.astro';
import { SITE_CONFIG } from '../config';

const writingEntries = await getCollection('writing', ({ data }) => data.draft !== true);
const sortedWriting = writingEntries.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout>
  <div class="grid grid-cols-1 md:grid-cols-12 gap-8">
    <!-- Main Content -->
    <div class="md:col-span-8 space-y-10 border-brand-text/10 px-8 pb-12 pt-0">
      <div>
        <h1 class="text-4xl font-semibold text-brand-text tracking-tight">
          {SITE_CONFIG.name}
        </h1>
        <p class="text-sm text-brand-text/50 mt-2 font-mono tracking-wide">Full Stack Developer</p>
      </div>

      <div class="space-y-4 text-brand-text/80 leading-relaxed text-[15px]">
        <p>
          I'm a developer and writer. I work at <a href="https://commandcode.ai" class="underline underline-offset-4 decoration-brand-text/40 hover:decoration-brand-text transition-colors">Command Code</a> building developer tools. Previously at <a href="https://www.pathaka.ai/" class="underline underline-offset-4 decoration-brand-text/40 hover:decoration-brand-text transition-colors">Pathaka AI</a>. I've been coding for 3+ years and I make technology easy to understand.
        </p>
      </div>

      <!-- ═══ EXPERIENCE ═══ -->
      <section>
        <h2 class="text-xl font-semibold mb-6 flex items-center gap-2">
          <span class="w-1 h-6 bg-brand-accent6"></span>
          Experience
        </h2>

        <div class="space-y-0">
          <!-- Command Code -->
          <details class="exp-card group border-t border-dashed border-brand-text/10">
            <summary class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between py-5 cursor-pointer select-none list-none [&::-webkit-details-marker]:hidden">
              <div class="flex-1 min-w-0 flex items-start gap-3">
                <img src="/langbase-logo-icon-only.png" alt="Command Code" class="exp-logo w-10 h-10 min-w-10 min-h-10 object-contain shrink-0" width="40" height="40" />
                <div class="min-w-0">
                <div class="flex items-center gap-2">
                  <h3 class="text-base font-semibold text-brand-text/95">Command Code</h3>
                  <svg class="exp-dropdown-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
                </div>
                <p class="text-sm text-brand-text/50 mt-0.5">Full Stack Developer</p>
                </div>
              </div>
              <div class="text-left sm:text-right shrink-0 sm:ml-6 sm:mt-0 mt-1">
                <p class="text-sm text-brand-text/50 font-mono">Mar 2025 — Present</p>
                <p class="text-xs text-brand-text/35 mt-0.5">San Francisco, Remote</p>
              </div>
            </summary>
            <div class="pb-5 -mt-1">
              <div class="flex flex-wrap gap-1.5 mb-4">
                <span class="px-2 py-0.5 text-[10px] font-mono text-brand-text/50 border border-dashed border-brand-text/10">Next.js</span>
                <span class="px-2 py-0.5 text-[10px] font-mono text-brand-text/50 border border-dashed border-brand-text/10">TypeScript</span>
                <span class="px-2 py-0.5 text-[10px] font-mono text-brand-text/50 border border-dashed border-brand-text/10">Supabase</span>
                <span class="px-2 py-0.5 text-[10px] font-mono text-brand-text/50 border border-dashed border-brand-text/10">React</span>
                <span class="px-2 py-0.5 text-[10px] font-mono text-brand-text/50 border border-dashed border-brand-text/10">Cloudflare</span>
                <span class="px-2 py-0.5 text-[10px] font-mono text-brand-text/50 border border-dashed border-brand-text/10">REST APIs</span>
              </div>
              <ul class="space-y-2.5 pl-4 border-l border-dashed border-brand-text/10">
                <li class="text-sm text-brand-text/60 leading-relaxed">Shipped 200+ PRs with 82% merge rate across 12 repositories spanning API, Dashboard, CLI, TypeScript SDK, Python SDK</li>
                <li class="text-sm text-brand-text/60 leading-relaxed">Built the official Python SDK from scratch — architected core primitives (agents, pipes, memory, threads, images), set up CI/CD pipeline, authored complete documentation</li>
                <li class="text-sm text-brand-text/60 leading-relaxed">Designed and implemented Skills CLI system with GitHub repo downloading, validation, and installation</li>
                <li class="text-sm text-brand-text/60 leading-relaxed">Implemented MCP (Model Context Protocol) end-to-end across backend API, TypeScript SDK, and Python SDK</li>
                <li class="text-sm text-brand-text/60 leading-relaxed">Integrated 9 new AI model integrations (Gemini 2.5/3, GPT 5.x, Claude 4.5, Grok 4.1, Deepseek V3.1) across multiple codebases</li>
                <li class="text-sm text-brand-text/60 leading-relaxed">Owned developer documentation — SDK references, API docs, 30+ code examples, 12+ integration guides</li>
                <li class="text-sm text-brand-text/60 leading-relaxed">Led SEO audits identifying 20+ issues, implemented JSON-LD schemas, deterministic OG images, and sitemap rewrites</li>
                <li class="text-sm text-brand-text/60 leading-relaxed">Built image support via @filepath and drag-drop with base64 encoding pipeline, developed changelog system in CLI with web UI</li>
              </ul>
            </div>
          </details>

          <!-- Pathaka AI -->
          <details class="exp-card group border-t border-b border-dashed border-brand-text/10">
            <summary class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between py-5 cursor-pointer select-none list-none [&::-webkit-details-marker]:hidden">
              <div class="flex-1 min-w-0 flex items-start gap-3">
                <img src="/pathaka-logo.webp" alt="Pathaka AI" class="exp-logo w-10 h-10 min-w-10 min-h-10 object-contain shrink-0" width="40" height="40" />
                <div class="min-w-0">
                <div class="flex items-center gap-2">
                  <h3 class="text-base font-semibold text-brand-text/95">Pathaka AI</h3>
                  <svg class="exp-dropdown-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
                </div>
                <p class="text-sm text-brand-text/50 mt-0.5">Software Engineering Intern</p>
                </div>
              </div>
              <div class="text-left sm:text-right shrink-0 sm:ml-6 sm:mt-0 mt-1">
                <p class="text-sm text-brand-text/50 font-mono">Oct 2024 — Jan 2025</p>
                <p class="text-xs text-brand-text/35 mt-0.5">London, Remote</p>
              </div>
            </summary>
            <div class="pb-5 -mt-1">
              <div class="flex flex-wrap gap-1.5 mb-4">
                <span class="px-2 py-0.5 text-[10px] font-mono text-brand-text/50 border border-dashed border-brand-text/10">Next.js</span>
                <span class="px-2 py-0.5 text-[10px] font-mono text-brand-text/50 border border-dashed border-brand-text/10">TypeScript</span>
                <span class="px-2 py-0.5 text-[10px] font-mono text-brand-text/50 border border-dashed border-brand-text/10">REST APIs</span>
                <span class="px-2 py-0.5 text-[10px] font-mono text-brand-text/50 border border-dashed border-brand-text/10">MongoDB</span>
                <span class="px-2 py-0.5 text-[10px] font-mono text-brand-text/50 border border-dashed border-brand-text/10">AWS</span>
              </div>
              <ul class="space-y-2.5 pl-4 border-l border-dashed border-brand-text/10">
                <li class="text-sm text-brand-text/60 leading-relaxed">Implemented podcast generation feature leveraging OpenAI and Eleven Labs text-to-speech</li>
                <li class="text-sm text-brand-text/60 leading-relaxed">Leveraged GPT-4o for podcast script generation across diverse topics with 95% content relevance</li>
                <li class="text-sm text-brand-text/60 leading-relaxed">Conducted TTS vs ElevenLabs comparison demonstrating 42% better voice naturalness</li>
                <li class="text-sm text-brand-text/60 leading-relaxed">Designed podcast creation UI with ChakraUI that improved user interaction by 48%</li>
              </ul>
            </div>
          </details>
        </div>
      </section>

      <!-- ═══ EDUCATION ═══ -->
      <section>
        <h2 class="text-xl font-semibold mb-6 flex items-center gap-2">
          <span class="w-1 h-6 bg-brand-accent5"></span>
          Education
        </h2>

        <div class="border-t border-b border-dashed border-brand-text/10 py-5">
          <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between sm:gap-4">
            <div class="flex items-start gap-3 min-w-0">
              <img src="/iit_logo_original.png" alt="IIT BHU" class="exp-logo w-10 h-10 min-w-10 min-h-10 object-contain shrink-0" width="40" height="40" />
              <div>
                <h3 class="text-base font-semibold text-brand-text/95">Indian Institute of Technology, Varanasi</h3>
                <p class="text-sm text-brand-text/50 mt-0.5">Bachelor of Technology (B.Tech) — IIT BHU</p>
              </div>
            </div>
            <div class="text-left sm:text-right shrink-0 sm:mt-0 mt-1">
              <p class="text-sm text-brand-text/50 font-mono">Jul 2021 — May 2025</p>
              <p class="text-xs text-brand-text/35 mt-0.5">Varanasi, India</p>
            </div>
          </div>
        </div>
      </section>

      <!-- ═══ WRITING ═══ -->
      <section>
        <h2 class="text-xl font-semibold mb-6 flex items-center gap-2">
          <span class="w-1 h-6 bg-brand-accent4"></span>
          Writing
        </h2>
        <ul class="space-y-2 pl-4 border-l border-dashed border-brand-text/20">
          {sortedWriting.map((entry) => (
            <li>
              <a href={`/writing/${entry.slug}`} class="underline underline-offset-4 decoration-brand-text/40 hover:decoration-brand-text transition-colors text-[15px]">{entry.data.title}</a>
            </li>
          ))}
        </ul>
      </section>

      <!-- ═══ PROJECTS ═══ -->
      <section>
        <h2 class="text-xl font-semibold mb-6 flex items-center gap-2">
          <span class="w-1 h-6 bg-brand-accent2"></span>
          Projects
        </h2>

        <div class="space-y-0">
          <details class="exp-card group border-t border-dashed border-brand-text/10">
            <summary class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between py-5 cursor-pointer select-none list-none [&::-webkit-details-marker]:hidden">
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-3">
                  <h3 class="text-base font-semibold text-brand-text/95">TermReel</h3>
                  <svg class="exp-dropdown-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
                  <a href="https://github.com/arre-ankit/termreel" target="_blank" rel="noopener noreferrer" class="text-[10px] font-mono text-brand-text/40 hover:text-brand-accent2 transition-colors" aria-label="View TermReel on GitHub">GitHub</a>
                </div>
                <p class="text-sm text-brand-text/50 mt-0.5">AI-powered CLI for terminal demo recordings</p>
              </div>
              <div class="text-left sm:text-right shrink-0 sm:ml-6 sm:mt-0 mt-1">
                <span class="px-2 py-0.5 text-[10px] font-mono text-brand-text/40 border border-dashed border-brand-text/10">TypeScript</span>
              </div>
            </summary>
            <div class="pb-5 -mt-1">
              <ul class="space-y-2.5 pl-4 border-l border-dashed border-brand-text/10">
                <li class="text-sm text-brand-text/60 leading-relaxed">Built an AI-powered CLI that generates terminal demo recordings (GIF/MP4/WebM) from plain English using VHS</li>
                <li class="text-sm text-brand-text/60 leading-relaxed">Integrated OpenAI and Anthropic APIs to auto-generate, refine, and fix demo scripts through an AI feedback loop</li>
                <li class="text-sm text-brand-text/60 leading-relaxed">Interactive CLI with theme injection and automated recording for polished terminal demos</li>
              </ul>
            </div>
          </details>

          <details class="exp-card group border-t border-dashed border-brand-text/10">
            <summary class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between py-5 cursor-pointer select-none list-none [&::-webkit-details-marker]:hidden">
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-3">
                  <h3 class="text-base font-semibold text-brand-text/95">PullScan</h3>
                  <svg class="exp-dropdown-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
                  <a href="https://github.com/arre-ankit/pullscan" target="_blank" rel="noopener noreferrer" class="text-[10px] font-mono text-brand-text/40 hover:text-brand-accent2 transition-colors" aria-label="View PullScan on GitHub">GitHub</a>
                </div>
                <p class="text-sm text-brand-text/50 mt-0.5">AI platform for GitHub commit and PR summaries</p>
              </div>
              <div class="text-left sm:text-right shrink-0 sm:ml-6 sm:mt-0 mt-1">
                <span class="px-2 py-0.5 text-[10px] font-mono text-brand-text/40 border border-dashed border-brand-text/10">Full Stack</span>
              </div>
            </summary>
            <div class="pb-5 -mt-1">
              <div class="flex flex-wrap gap-1.5 mb-4">
                <span class="px-2 py-0.5 text-[10px] font-mono text-brand-text/50 border border-dashed border-brand-text/10">Next.js 15</span>
                <span class="px-2 py-0.5 text-[10px] font-mono text-brand-text/50 border border-dashed border-brand-text/10">Express</span>
                <span class="px-2 py-0.5 text-[10px] font-mono text-brand-text/50 border border-dashed border-brand-text/10">Prisma</span>
                <span class="px-2 py-0.5 text-[10px] font-mono text-brand-text/50 border border-dashed border-brand-text/10">PostgreSQL</span>
                <span class="px-2 py-0.5 text-[10px] font-mono text-brand-text/50 border border-dashed border-brand-text/10">QStash</span>
              </div>
              <ul class="space-y-2.5 pl-4 border-l border-dashed border-brand-text/10">
                <li class="text-sm text-brand-text/60 leading-relaxed">Monorepo with Next.js frontend and Express.js backend, Prisma ORM, Clerk auth, and Zod validation</li>
                <li class="text-sm text-brand-text/60 leading-relaxed">Engineered RAG-based chat system using LangBase vector memory and LangChain's GithubRepoLoader for natural language codebase queries</li>
                <li class="text-sm text-brand-text/60 leading-relaxed">Implemented async background job processing with Upstash QStash for expensive repo indexing</li>
              </ul>
            </div>
          </details>

          <details class="exp-card group border-t border-b border-dashed border-brand-text/10">
            <summary class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between py-5 cursor-pointer select-none list-none [&::-webkit-details-marker]:hidden">
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-3 flex-wrap">
                  <h3 class="text-base font-semibold text-brand-text/95">PINN for Structural Mechanics</h3>
                  <svg class="exp-dropdown-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
                  <a href="https://github.com/arre-ankit/Physics-Informed-Neural-Networks-PINNs-" target="_blank" rel="noopener noreferrer" class="text-[10px] font-mono text-brand-text/40 hover:text-brand-accent2 transition-colors" aria-label="View PINN for Structural Mechanics on GitHub">GitHub</a>
                </div>
                <p class="text-sm text-brand-text/50 mt-0.5">Under Prof. Kshitij Kumar Yadav, IIT BHU</p>
              </div>
              <div class="text-left sm:text-right shrink-0 sm:ml-6 sm:mt-0 mt-1">
                <span class="px-2 py-0.5 text-[10px] font-mono text-brand-text/40 border border-dashed border-brand-text/10">Python</span>
              </div>
            </summary>
            <div class="pb-5 -mt-1">
              <div class="flex flex-wrap gap-1.5 mb-4">
                <span class="px-2 py-0.5 text-[10px] font-mono text-brand-text/50 border border-dashed border-brand-text/10">DeepXDE</span>
                <span class="px-2 py-0.5 text-[10px] font-mono text-brand-text/50 border border-dashed border-brand-text/10">TensorFlow</span>
                <span class="px-2 py-0.5 text-[10px] font-mono text-brand-text/50 border border-dashed border-brand-text/10">NumPy</span>
                <span class="px-2 py-0.5 text-[10px] font-mono text-brand-text/50 border border-dashed border-brand-text/10">Matplotlib</span>
              </div>
              <ul class="space-y-2.5 pl-4 border-l border-dashed border-brand-text/10">
                <li class="text-sm text-brand-text/60 leading-relaxed">Built and trained PINNs on the Timoshenko Equation to predict beam deflection at any distance and time</li>
                <li class="text-sm text-brand-text/60 leading-relaxed">Utilized DeepXDE with TensorFlow backend to manage complex mathematical equations</li>
                <li class="text-sm text-brand-text/60 leading-relaxed">Achieved a loss of 3.88e-07 comparing PINN predictions with traditional solutions</li>
              </ul>
            </div>
          </details>
        </div>
      </section>
    </div>

    <!-- Sidebar -->
    <div class="md:col-span-4 space-y-0 pt-0">

      <!-- Tic-Tac-Toe Game -->
      <TicTacToe />

      <!-- Social Connect -->
      <div class="relative border-t border-l border-r border-dashed border-brand-text/10 p-6 bg-brand-text/[0.01]">
        <h3 class="text-xs font-semibold text-brand-text/60 mb-4 tracking-widest uppercase flex items-center gap-2">
          <span class="w-1.5 h-1.5 bg-brand-accent2 rotate-45"></span>
          Connect
        </h3>

        <div class="space-y-2">
          <a href="https://twitter.com/arre_ankit" class="group flex items-center justify-between p-3 border border-dashed border-brand-text/10 hover:border-brand-text/20 bg-brand-text/[0.01] hover:bg-brand-text/[0.02] transition-colors">
            <span class="text-sm text-brand-text/70 group-hover:text-brand-text transition-colors">Twitter</span>
            <svg class="w-4 h-4 text-brand-text/40 group-hover:text-brand-text/70 transition-colors" fill="currentColor" viewBox="0 0 24 24">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>

          <a href="https://github.com/arre-ankit" class="group flex items-center justify-between p-3 border border-dashed border-brand-text/10 hover:border-brand-text/20 bg-brand-text/[0.01] hover:bg-brand-text/[0.02] transition-colors">
            <span class="text-sm text-brand-text/70 group-hover:text-brand-text transition-colors">GitHub</span>
            <svg class="w-4 h-4 text-brand-text/40 group-hover:text-brand-text/70 transition-colors" fill="currentColor" viewBox="0 0 24 24">
              <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/>
            </svg>
          </a>

          <a href="https://linkedin.com/in/arre-ankit" class="group flex items-center justify-between p-3 border border-dashed border-brand-text/10 hover:border-brand-text/20 bg-brand-text/[0.01] hover:bg-brand-text/[0.02] transition-colors">
            <span class="text-sm text-brand-text/70 group-hover:text-brand-text transition-colors">LinkedIn</span>
            <svg class="w-4 h-4 text-brand-text/40 group-hover:text-brand-text/70 transition-colors" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Skills -->
      <div class="relative border-t border-l border-r border-dashed border-brand-text/10 p-6 bg-brand-text/[0.01]">
        <h3 class="text-xs font-semibold text-brand-text/60 mb-4 tracking-widest uppercase flex items-center gap-2">
          <span class="w-1.5 h-1.5 bg-brand-accent4 rotate-45"></span>
          Skills
        </h3>

        <div class="space-y-4">
          <div>
            <p class="text-[10px] font-mono text-brand-text/35 uppercase tracking-wider mb-2">Languages</p>
            <div class="flex flex-wrap gap-1.5">
              <span class="px-2 py-1 border border-dashed border-brand-text/10 bg-brand-text/[0.01] text-xs text-brand-text/60">TypeScript</span>
              <span class="px-2 py-1 border border-dashed border-brand-text/10 bg-brand-text/[0.01] text-xs text-brand-text/60">JavaScript</span>
              <span class="px-2 py-1 border border-dashed border-brand-text/10 bg-brand-text/[0.01] text-xs text-brand-text/60">Python</span>
            </div>
          </div>

          <div>
            <p class="text-[10px] font-mono text-brand-text/35 uppercase tracking-wider mb-2">Frameworks</p>
            <div class="flex flex-wrap gap-1.5">
              <span class="px-2 py-1 border border-dashed border-brand-text/10 bg-brand-text/[0.01] text-xs text-brand-text/60">React</span>
              <span class="px-2 py-1 border border-dashed border-brand-text/10 bg-brand-text/[0.01] text-xs text-brand-text/60">Next.js</span>
              <span class="px-2 py-1 border border-dashed border-brand-text/10 bg-brand-text/[0.01] text-xs text-brand-text/60">Node.js</span>
