---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import MobileNav from '../components/MobileNav.astro';
import StackSection from '../components/StackSection.astro';

const writingEntries = await getCollection('writing', ({ data }) => data.draft !== true);
const sortedWriting = writingEntries.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout>
  <SiteHeader variant="hero" />
  <MobileNav barless title="Ankit Kumar" items={sortedWriting.map((p) => ({ slug: p.slug, title: p.data.title }))} />

  <div class="space-y-10 px-5 sm:px-8 pb-12 pt-0">
      <div class="space-y-4 text-brand-text/80 leading-relaxed text-[15px]">
        <p>
          I'm a developer and writer. I work at <a href="https://commandcode.ai" class="underline underline-offset-4 decoration-brand-text/40 hover:decoration-brand-text transition-colors">Command Code</a> building developer tools. Previously at <a href="https://www.pathaka.ai/" class="underline underline-offset-4 decoration-brand-text/40 hover:decoration-brand-text transition-colors">Pathaka AI</a>. I've been coding for 3+ years and I make technology easy to understand.
        </p>
      </div>

      <!-- ═══ EXPERIENCE ═══ -->
      <section>
        <h2 class="text-xl font-semibold mb-3">
          Experience
        </h2>

        <div class="space-y-0">
          <!-- Command Code -->
          <details class="exp-card group border-t border-solid border-brand-text/10">
            <summary class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between py-5 cursor-pointer select-none list-none [&::-webkit-details-marker]:hidden">
              <div class="flex-1 min-w-0 flex items-start gap-3">
                <img src="/langbase-logo-icon-only.png" alt="Command Code" class="exp-logo w-10 h-10 min-w-10 min-h-10 object-contain shrink-0" width="40" height="40" />
                <div class="min-w-0">
                <div class="flex items-center gap-2">
                  <h3 class="text-base font-semibold text-brand-text/95">Command Code</h3>
                  <svg class="exp-dropdown-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
                </div>
                <p class="text-sm text-brand-text/50 mt-0.5">Full Stack Developer</p>
                </div>
              </div>
              <div class="text-left sm:text-right shrink-0 sm:ml-6 sm:mt-0 mt-1">
                <p class="text-sm text-brand-text/50 font-mono">Mar 2025 — Present</p>
                <p class="text-xs text-brand-text/35 mt-0.5">San Francisco, Remote</p>
              </div>
            </summary>
            <div class="pb-5 -mt-1">
              <div class="flex flex-wrap gap-1.5 mb-4">
                <span class="px-2 py-0.5 text-[10px] font-mono text-brand-text/50 border border-solid border-brand-text/10">Next.js</span>
                <span class="px-2 py-0.5 text-[10px] font-mono text-brand-text/50 border border-solid border-brand-text/10">TypeScript</span>
                <span class="px-2 py-0.5 text-[10px] font-mono text-brand-text/50 border border-solid border-brand-text/10">Supabase</span>
                <span class="px-2 py-0.5 text-[10px] font-mono text-brand-text/50 border border-solid border-brand-text/10">React</span>
                <span class="px-2 py-0.5 text-[10px] font-mono text-brand-text/50 border border-solid border-brand-text/10">Cloudflare</span>
                <span class="px-2 py-0.5 text-[10px] font-mono text-brand-text/50 border border-solid border-brand-text/10">REST APIs</span>
              </div>
              <ul class="space-y-2.5 pl-4 border-l border-solid border-brand-text/10">
                <li class="text-sm text-brand-text/60 leading-relaxed">Shipped 200+ PRs with 82% merge rate across 12 repositories spanning API, Dashboard, CLI, TypeScript SDK, Python SDK</li>
                <li class="text-sm text-brand-text/60 leading-relaxed">Built the official Python SDK from scratch — architected core primitives (agents, pipes, memory, threads, images), set up CI/CD pipeline, authored complete documentation</li>
                <li class="text-sm text-brand-text/60 leading-relaxed">Designed and implemented Skills CLI system with GitHub repo downloading, validation, and installation</li>
                <li class="text-sm text-brand-text/60 leading-relaxed">Implemented MCP (Model Context Protocol) end-to-end across backend API, TypeScript SDK, and Python SDK</li>
                <li class="text-sm text-brand-text/60 leading-relaxed">Integrated 9 new AI model integrations (Gemini 2.5/3, GPT 5.x, Claude 4.5, Grok 4.1, Deepseek V3.1) across multiple codebases</li>
                <li class="text-sm text-brand-text/60 leading-relaxed">Owned developer documentation — SDK references, API docs, 30+ code examples, 12+ integration guides</li>
                <li class="text-sm text-brand-text/60 leading-relaxed">Led SEO audits identifying 20+ issues, implemented JSON-LD schemas, deterministic OG images, and sitemap rewrites</li>
                <li class="text-sm text-brand-text/60 leading-relaxed">Built image support via @filepath and drag-drop with base64 encoding pipeline, developed changelog system in CLI with web UI</li>
              </ul>
            </div>
          </details>

          <!-- Pathaka AI -->
          <details class="exp-card group border-t border-b border-solid border-brand-text/10">
            <summary class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between py-5 cursor-pointer select-none list-none [&::-webkit-details-marker]:hidden">
              <div class="flex-1 min-w-0 flex items-start gap-3">
                <img src="/pathaka-logo.webp" alt="Pathaka AI" class="exp-logo w-10 h-10 min-w-10 min-h-10 object-contain shrink-0" width="40" height="40" />
                <div class="min-w-0">
                <div class="flex items-center gap-2">
                  <h3 class="text-base font-semibold text-brand-text/95">Pathaka AI</h3>
                  <svg class="exp-dropdown-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
                </div>
                <p class="text-sm text-brand-text/50 mt-0.5">Software Engineering Intern</p>
                </div>
              </div>
              <div class="text-left sm:text-right shrink-0 sm:ml-6 sm:mt-0 mt-1">
                <p class="text-sm text-brand-text/50 font-mono">Oct 2024 — Jan 2025</p>
                <p class="text-xs text-brand-text/35 mt-0.5">London, Remote</p>
              </div>
            </summary>
            <div class="pb-5 -mt-1">
              <div class="flex flex-wrap gap-1.5 mb-4">
                <span class="px-2 py-0.5 text-[10px] font-mono text-brand-text/50 border border-solid border-brand-text/10">Next.js</span>
                <span class="px-2 py-0.5 text-[10px] font-mono text-brand-text/50 border border-solid border-brand-text/10">TypeScript</span>
                <span class="px-2 py-0.5 text-[10px] font-mono text-brand-text/50 border border-solid border-brand-text/10">REST APIs</span>
                <span class="px-2 py-0.5 text-[10px] font-mono text-brand-text/50 border border-solid border-brand-text/10">MongoDB</span>
                <span class="px-2 py-0.5 text-[10px] font-mono text-brand-text/50 border border-solid border-brand-text/10">AWS</span>
              </div>
              <ul class="space-y-2.5 pl-4 border-l border-solid border-brand-text/10">
                <li class="text-sm text-brand-text/60 leading-relaxed">Implemented podcast generation feature leveraging OpenAI and Eleven Labs text-to-speech</li>
                <li class="text-sm text-brand-text/60 leading-relaxed">Leveraged GPT-4o for podcast script generation across diverse topics with 95% content relevance</li>
                <li class="text-sm text-brand-text/60 leading-relaxed">Conducted TTS vs ElevenLabs comparison demonstrating 42% better voice naturalness</li>
                <li class="text-sm text-brand-text/60 leading-relaxed">Designed podcast creation UI with ChakraUI that improved user interaction by 48%</li>
              </ul>
            </div>
          </details>
        </div>
      </section>

      <!-- ═══ EDUCATION ═══ -->
      <section>
        <h2 class="text-xl font-semibold mb-3">
          Education
        </h2>

        <div class="border-t border-b border-solid border-brand-text/10 py-5">
          <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between sm:gap-4">
            <div class="flex items-start gap-3 min-w-0">
              <img src="/iit_logo_original.png" alt="IIT BHU" class="exp-logo w-10 h-10 min-w-10 min-h-10 object-contain shrink-0" width="40" height="40" />
              <div>
                <h3 class="text-base font-semibold text-brand-text/95">Indian Institute of Technology, Varanasi</h3>
                <p class="text-sm text-brand-text/50 mt-0.5">Bachelor of Technology (B.Tech) — IIT BHU</p>
              </div>
            </div>
            <div class="text-left sm:text-right shrink-0 sm:mt-0 mt-1">
              <p class="text-sm text-brand-text/50 font-mono">Jul 2021 — May 2025</p>
              <p class="text-xs text-brand-text/35 mt-0.5">Varanasi, India</p>
            </div>
          </div>
        </div>
      </section>

      <!-- ═══ WRITING ═══ -->
      <section>
        <div class="flex items-baseline justify-between mb-3">
          <h2 class="text-xl font-semibold">Writing</h2>
          <a href="/writing" class="font-pixel text-[10px] uppercase tracking-wide text-brand-text/40 hover:text-brand-text transition-colors">All →</a>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-3 border-t border-solid border-brand-text/10">
          {sortedWriting.slice(0, 3).map((entry, index) => (
            <a
              href={`/writing/${entry.slug}`}
              class="group flex flex-col py-6 sm:px-5 sm:first:pl-0 sm:last:pr-0 sm:border-l sm:border-solid sm:border-brand-text/10 sm:first:border-l-0"
            >
              <div class="relative aspect-[4/3] mb-4 flex items-center justify-center overflow-hidden border border-solid border-brand-text/15 bg-brand-text/[0.015] dark:bg-white/[0.02] group-hover:border-brand-text/30 transition-colors">
                {entry.data.cover ? (
                  <img src={entry.data.cover} alt={entry.data.title} class="absolute inset-0 w-full h-full object-cover" loading="lazy" />
                ) : (
                  <span class="font-pixel text-6xl text-brand-text/[0.08] group-hover:text-[#0D3EFF]/25 dark:group-hover:text-[#FF5F1F]/30 transition-colors select-none">
                    {String(index + 1).padStart(2, '0')}
                  </span>
                )}
              </div>
              <h3 class="text-lg text-brand-text/90 group-hover:text-[#0D3EFF] dark:group-hover:text-[#FF5F1F] transition-colors leading-snug">
                {entry.data.title}
              </h3>
              {entry.data.description && (
                <p class="text-sm text-brand-text/55 mt-2 leading-relaxed">{entry.data.description}</p>
              )}
            </a>
          ))}
        </div>
      </section>

      <!-- ═══ STACK ═══ -->
      <StackSection />

      <!-- ═══ PROJECTS ═══ -->
      <section>
        <h2 class="text-xl font-semibold mb-3">
          Projects
        </h2>

        <div class="space-y-0">
          <details class="exp-card group border-t border-solid border-brand-text/10">
            <summary class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between py-5 cursor-pointer select-none list-none [&::-webkit-details-marker]:hidden">
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-3">
                  <h3 class="text-base font-semibold text-brand-text/95">TermReel</h3>
                  <svg class="exp-dropdown-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
                  <a href="https://github.com/arre-ankit/termreel" target="_blank" rel="noopener noreferrer" class="text-[10px] font-mono text-brand-text/40 hover:text-brand-accent2 transition-colors" aria-label="View TermReel on GitHub">GitHub</a>
                </div>
                <p class="text-sm text-brand-text/50 mt-0.5">AI-powered CLI for terminal demo recordings</p>
              </div>
              <div class="text-left sm:text-right shrink-0 sm:ml-6 sm:mt-0 mt-1">
                <span class="px-2 py-0.5 text-[10px] font-mono text-brand-text/40 border border-solid border-brand-text/10">TypeScript</span>
              </div>
            </summary>
            <div class="pb-5 -mt-1">
              <ul class="space-y-2.5 pl-4 border-l border-solid border-brand-text/10">
                <li class="text-sm text-brand-text/60 leading-relaxed">Built an AI-powered CLI that generates terminal demo recordings (GIF/MP4/WebM) from plain English using VHS</li>
                <li class="text-sm text-brand-text/60 leading-relaxed">Integrated OpenAI and Anthropic APIs to auto-generate, refine, and fix demo scripts through an AI feedback loop</li>
                <li class="text-sm text-brand-text/60 leading-relaxed">Interactive CLI with theme injection and automated recording for polished terminal demos</li>
              </ul>
            </div>
          </details>

          <details class="exp-card group border-t border-solid border-brand-text/10">
            <summary class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between py-5 cursor-pointer select-none list-none [&::-webkit-details-marker]:hidden">
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-3">
                  <h3 class="text-base font-semibold text-brand-text/95">PullScan</h3>
                  <svg class="exp-dropdown-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
                  <a href="https://github.com/arre-ankit/pullscan" target="_blank" rel="noopener noreferrer" class="text-[10px] font-mono text-brand-text/40 hover:text-brand-accent2 transition-colors" aria-label="View PullScan on GitHub">GitHub</a>
                </div>
                <p class="text-sm text-brand-text/50 mt-0.5">AI platform for GitHub commit and PR summaries</p>
              </div>
              <div class="text-left sm:text-right shrink-0 sm:ml-6 sm:mt-0 mt-1">
                <span class="px-2 py-0.5 text-[10px] font-mono text-brand-text/40 border border-solid border-brand-text/10">Full Stack</span>
              </div>
            </summary>
            <div class="pb-5 -mt-1">
              <div class="flex flex-wrap gap-1.5 mb-4">
                <span class="px-2 py-0.5 text-[10px] font-mono text-brand-text/50 border border-solid border-brand-text/10">Next.js 15</span>
                <span class="px-2 py-0.5 text-[10px] font-mono text-brand-text/50 border border-solid border-brand-text/10">Express</span>
                <span class="px-2 py-0.5 text-[10px] font-mono text-brand-text/50 border border-solid border-brand-text/10">Prisma</span>
                <span class="px-2 py-0.5 text-[10px] font-mono text-brand-text/50 border border-solid border-brand-text/10">PostgreSQL</span>
                <span class="px-2 py-0.5 text-[10px] font-mono text-brand-text/50 border border-solid border-brand-text/10">QStash</span>
              </div>
              <ul class="space-y-2.5 pl-4 border-l border-solid border-brand-text/10">
                <li class="text-sm text-brand-text/60 leading-relaxed">Monorepo with Next.js frontend and Express.js backend, Prisma ORM, Clerk auth, and Zod validation</li>
                <li class="text-sm text-brand-text/60 leading-relaxed">Engineered RAG-based chat system using LangBase vector memory and LangChain's GithubRepoLoader for natural language codebase queries</li>
                <li class="text-sm text-brand-text/60 leading-relaxed">Implemented async background job processing with Upstash QStash for expensive repo indexing</li>
              </ul>
            </div>
          </details>

          <details class="exp-card group border-t border-b border-solid border-brand-text/10">
            <summary class="flex flex-col gap-2 sm:flex-row sm:items-start sm:justify-between py-5 cursor-pointer select-none list-none [&::-webkit-details-marker]:hidden">
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-3 flex-wrap">
                  <h3 class="text-base font-semibold text-brand-text/95">PINN for Structural Mechanics</h3>
                  <svg class="exp-dropdown-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
                  <a href="https://github.com/arre-ankit/Physics-Informed-Neural-Networks-PINNs-" target="_blank" rel="noopener noreferrer" class="text-[10px] font-mono text-brand-text/40 hover:text-brand-accent2 transition-colors" aria-label="View PINN for Structural Mechanics on GitHub">GitHub</a>
                </div>
                <p class="text-sm text-brand-text/50 mt-0.5">Under Prof. Kshitij Kumar Yadav, IIT BHU</p>
              </div>
              <div class="text-left sm:text-right shrink-0 sm:ml-6 sm:mt-0 mt-1">
                <span class="px-2 py-0.5 text-[10px] font-mono text-brand-text/40 border border-solid border-brand-text/10">Python</span>
              </div>
            </summary>
            <div class="pb-5 -mt-1">
              <div class="flex flex-wrap gap-1.5 mb-4">
                <span class="px-2 py-0.5 text-[10px] font-mono text-brand-text/50 border border-solid border-brand-text/10">DeepXDE</span>
                <span class="px-2 py-0.5 text-[10px] font-mono text-brand-text/50 border border-solid border-brand-text/10">TensorFlow</span>
                <span class="px-2 py-0.5 text-[10px] font-mono text-brand-text/50 border border-solid border-brand-text/10">NumPy</span>
                <span class="px-2 py-0.5 text-[10px] font-mono text-brand-text/50 border border-solid border-brand-text/10">Matplotlib</span>
              </div>
              <ul class="space-y-2.5 pl-4 border-l border-solid border-brand-text/10">
                <li class="text-sm text-brand-text/60 leading-relaxed">Built and trained PINNs on the Timoshenko Equation to predict beam deflection at any distance and time</li>
                <li class="text-sm text-brand-text/60 leading-relaxed">Utilized DeepXDE with TensorFlow backend to manage complex mathematical equations</li>
                <li class="text-sm text-brand-text/60 leading-relaxed">Achieved a loss of 3.88e-07 comparing PINN predictions with traditional solutions</li>
              </ul>
            </div>
          </details>
        </div>
      </section>
    </div>
</BaseLayout>

<style>
  .exp-dropdown-icon {
    flex-shrink: 0;
    color: color-mix(in srgb, var(--text-primary) 40%, transparent);
    transition: transform 0.2s ease, color 0.2s ease;
  }

  details.exp-card[open] .exp-dropdown-icon {
    transform: rotate(180deg);
    color: color-mix(in srgb, var(--text-primary) 70%, transparent);
  }

  details.exp-card summary:hover .exp-dropdown-icon {
    color: color-mix(in srgb, var(--text-primary) 70%, transparent);
  }

  details.exp-card[open] > div {
    animation: slideDown 0.2s ease-out;
  }

  @keyframes slideDown {
    from {
      opacity: 0;
      transform: translateY(-4px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    details.exp-card[open] > div {
      animation: none;
    }
    .exp-dropdown-icon {
      transition: none;
    }
  }
</style>
