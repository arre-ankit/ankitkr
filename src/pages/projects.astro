---
import BaseLayout from '../layouts/BaseLayout.astro';

const projects = [
  {
    slug: 'example-project-1',
    name: 'Example Project 1',
    description: 'A brief description of what this project does and why it matters.',
    link: 'https://github.com/yourusername/project1',
    demo: 'https://project1.demo.com',
    tags: ['TypeScript', 'React', 'Tailwind'],
    status: 'Active',
    year: '2024',
  },
  {
    slug: 'example-project-2',
    name: 'Example Project 2',
    description: 'Another interesting project that showcases your skills and interests.',
    link: 'https://github.com/yourusername/project2',
    demo: 'https://project2.demo.com',
    tags: ['Python', 'FastAPI', 'PostgreSQL'],
    status: 'Active',
    year: '2023',
  },
  {
    slug: 'example-project-3',
    name: 'Example Project 3',
    description: 'A third project demonstrating your range and expertise.',
    link: 'https://github.com/yourusername/project3',
    demo: null,
    tags: ['Astro', 'MDX', 'Design'],
    status: 'Archived',
    year: '2023',
  },
];
---

<BaseLayout title="Projects" description="Things I've built">
  <div class="grid grid-cols-1 md:grid-cols-12 gap-8">
    <!-- Main Content - Centered Projects -->
    <div class="md:col-span-8 space-y-8 border-brand-text/10 px-8 pb-12 pt-0">
      <div class="space-y-2">
        <h1 class="text-4xl font-semibold text-brand-text tracking-tight">Projects</h1>
        <p class="text-brand-text/70">Things I've built</p>
      </div>

      <div class="space-y-4">
        {projects.map((project) => (
          <article class="pb-4 border-b border-dashed border-brand-text/10 last:border-b-0 hover:bg-brand-text/[0.01] transition-all p-3 -mx-3">
            <div class="flex items-start gap-3 mb-2">
              <div class="flex-1">
                <div class="flex items-center gap-3 mb-1.5">
                  <a href={`/projects/${project.slug}`} class="hover:text-brand-accent2 transition-colors">
                    <h2 class="text-base font-medium text-brand-text hover:text-brand-accent2 transition-colors">
                      {project.name}
                    </h2>
                  </a>
                  <a
                    href={project.link}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-1.5 text-xs text-brand-text/50 hover:text-brand-text transition-colors border border-dashed border-brand-text/10 hover:border-brand-accent2 px-2 py-1"
                  >
                    <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24">
                      <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/>
                    </svg>
                    GitHub
                  </a>
                  {project.demo && (
                    <a
                      href={project.demo}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex items-center gap-1.5 text-xs text-brand-text/50 hover:text-brand-text transition-colors border border-dashed border-brand-text/10 hover:border-brand-accent3 px-2 py-1"
                    >
                      <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                      </svg>
                      Live Demo
                    </a>
                  )}
                </div>
                <p class="text-brand-text/80 text-sm leading-relaxed mb-2">
                  {project.description}
                </p>
                <div class="flex flex-wrap items-center gap-2">
                  <div class="flex flex-wrap gap-2">
                    {project.tags.map((tag) => (
                      <span class="px-2 py-1 border border-dashed border-brand-text/10 bg-brand-text/[0.01] text-xs text-brand-text/60">
                        {tag}
                      </span>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>

    <!-- Creative Sidebar for Projects -->
    <div class="md:col-span-4 space-y-0 pt-0">
      <!-- Tech Stack Card -->
      <div class="relative border-t border-l border-r border-dashed border-brand-text/10 p-6 bg-brand-text/[0.01]">
        <div class="absolute top-0 left-0 w-3 h-3 border-l-2 border-t-2 border-brand-accent3"></div>

        <div class="flex items-center gap-2 mb-4">
          <span class="text-2xl">🛠️</span>
          <h3 class="text-xs font-semibold text-brand-text/60 tracking-widest uppercase">Tech Stack</h3>
        </div>

        <div class="grid grid-cols-3 gap-3">
          <div class="aspect-square border border-dashed border-brand-text/10 bg-brand-text/[0.01] hover:bg-brand-text/[0.02] hover:border-brand-accent2 transition-all flex flex-col items-center justify-center p-3 group">
            <span class="text-2xl group-hover:scale-110 transition-transform">📘</span>
            <p class="text-[10px] text-brand-text/60 text-center leading-tight mt-1">TypeScript</p>
          </div>

          <div class="aspect-square border border-dashed border-brand-text/10 bg-brand-text/[0.01] hover:bg-brand-text/[0.02] hover:border-brand-accent2 transition-all flex flex-col items-center justify-center p-3 group">
            <span class="text-2xl group-hover:scale-110 transition-transform">⚛️</span>
            <p class="text-[10px] text-brand-text/60 text-center leading-tight mt-1">React</p>
          </div>

          <div class="aspect-square border border-dashed border-brand-text/10 bg-brand-text/[0.01] hover:bg-brand-text/[0.02] hover:border-brand-accent2 transition-all flex flex-col items-center justify-center p-3 group">
            <span class="text-2xl group-hover:scale-110 transition-transform">🎨</span>
            <p class="text-[10px] text-brand-text/60 text-center leading-tight mt-1">Tailwind</p>
          </div>

          <div class="aspect-square border border-dashed border-brand-text/10 bg-brand-text/[0.01] hover:bg-brand-text/[0.02] hover:border-brand-accent2 transition-all flex flex-col items-center justify-center p-3 group">
            <span class="text-2xl group-hover:scale-110 transition-transform">🐍</span>
            <p class="text-[10px] text-brand-text/60 text-center leading-tight mt-1">Python</p>
          </div>

          <div class="aspect-square border border-dashed border-brand-text/10 bg-brand-text/[0.01] hover:bg-brand-text/[0.02] hover:border-brand-accent2 transition-all flex flex-col items-center justify-center p-3 group">
            <span class="text-2xl group-hover:scale-110 transition-transform">⚡</span>
            <p class="text-[10px] text-brand-text/60 text-center leading-tight mt-1">FastAPI</p>
          </div>

          <div class="aspect-square border border-dashed border-brand-text/10 bg-brand-text/[0.01] hover:bg-brand-text/[0.02] hover:border-brand-accent2 transition-all flex flex-col items-center justify-center p-3 group">
            <span class="text-2xl group-hover:scale-110 transition-transform">🐘</span>
            <p class="text-[10px] text-brand-text/60 text-center leading-tight mt-1">PostgreSQL</p>
          </div>

          <div class="aspect-square border border-dashed border-brand-text/10 bg-brand-text/[0.01] hover:bg-brand-text/[0.02] hover:border-brand-accent2 transition-all flex flex-col items-center justify-center p-3 group">
            <span class="text-2xl group-hover:scale-110 transition-transform">🚀</span>
            <p class="text-[10px] text-brand-text/60 text-center leading-tight mt-1">Astro</p>
          </div>

          <div class="aspect-square border border-dashed border-brand-text/10 bg-brand-text/[0.01] hover:bg-brand-text/[0.02] hover:border-brand-accent2 transition-all flex flex-col items-center justify-center p-3 group">
            <span class="text-2xl group-hover:scale-110 transition-transform">📝</span>
            <p class="text-[10px] text-brand-text/60 text-center leading-tight mt-1">MDX</p>
          </div>

          <div class="aspect-square border border-dashed border-brand-text/10 bg-brand-text/[0.01] hover:bg-brand-text/[0.02] hover:border-brand-accent2 transition-all flex flex-col items-center justify-center p-3 group">
            <span class="text-2xl group-hover:scale-110 transition-transform">✨</span>
            <p class="text-[10px] text-brand-text/60 text-center leading-tight mt-1">Design</p>
          </div>
        </div>
      </div>

      <!-- Project Stats -->
      <div class="relative border-t border-l border-r border-dashed border-brand-text/10 p-6 bg-brand-text/[0.01]">
        <h3 class="text-xs font-semibold text-brand-text/60 mb-4 tracking-widest uppercase flex items-center gap-2">
          <span class="w-1.5 h-1.5 bg-brand-accent2 rotate-45"></span>
          Stats
        </h3>

        <div class="grid grid-cols-2 gap-3">
          <div class="text-center p-3 border border-dashed border-brand-text/10 bg-brand-text/[0.01]">
            <p class="text-2xl font-semibold text-brand-text mb-1">{projects.length}</p>
            <p class="text-xs text-brand-text/60">Projects</p>
          </div>

          <div class="text-center p-3 border border-dashed border-brand-text/10 bg-brand-text/[0.01]">
            <p class="text-2xl font-semibold text-brand-text mb-1">{projects.filter(p => p.status === 'Active').length}</p>
            <p class="text-xs text-brand-text/60">Active</p>
          </div>
        </div>
      </div>

      <!-- Open Source Contribution -->
      <div class="relative border-t border-l border-r border-dashed border-brand-text/10 p-6 bg-brand-text/[0.01]">
        <h3 class="text-xs font-semibold text-brand-text/60 mb-4 tracking-widest uppercase flex items-center gap-2">
          <span class="w-1.5 h-1.5 bg-brand-accent4 rotate-45"></span>
          Open Source
        </h3>

        <div class="space-y-3">
          <p class="text-sm text-brand-text/70 leading-relaxed">
            I believe in open source and try to contribute back to the community whenever possible.
          </p>

          <a href="https://github.com/yourusername" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-sm font-medium text-brand-text hover:text-brand-accent4 transition-colors border-b border-dashed border-brand-text/20 hover:border-brand-accent4 pb-0.5">
            View GitHub
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Featured Project -->
      <div class="relative border-t border-l border-r border-dashed border-brand-text/10 p-6 bg-brand-text/[0.01]">
        <h3 class="text-xs font-semibold text-brand-text/60 mb-4 tracking-widest uppercase flex items-center gap-2">
          <span class="w-1.5 h-1.5 bg-brand-accent5 rotate-45"></span>
          Featured
        </h3>

        <div class="pl-4 border-l-2 border-dashed border-brand-accent5/30">
          <p class="text-sm text-brand-text/80 font-medium mb-1">{projects[0].name}</p>
          <p class="text-xs text-brand-text/60 leading-relaxed mb-2">
            Currently my most active project
          </p>
          <a href={`/projects/${projects[0].slug}`} class="text-xs text-brand-accent5 hover:underline">
            Learn more →
          </a>
        </div>
      </div>

      <!-- Collaboration CTA -->
      <div class="relative border border-dashed border-brand-text/10 p-6 bg-brand-text/[0.01] group hover:bg-brand-text/[0.03] transition-all">
        <div class="absolute bottom-0 right-0 w-3 h-3 border-r-2 border-b-2 border-brand-accent3"></div>

        <h3 class="text-xs font-semibold text-brand-text/60 mb-3 tracking-widest uppercase">Collaborate</h3>

        <p class="text-sm text-brand-text/70 leading-relaxed mb-4">
          Interested in working together? Let's build something great.
        </p>

        <a href="mailto:collaborate@example.com" class="inline-flex items-center gap-2 text-sm font-medium text-brand-text hover:text-brand-accent3 transition-colors border-b border-dashed border-brand-text/20 hover:border-brand-accent3 pb-0.5">
          Get in touch
          <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
