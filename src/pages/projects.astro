---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import MobileNav from '../components/MobileNav.astro';
import { projects } from '../data/projects';
---

<BaseLayout title="Projects" description="Things I've built">
  <div class="hidden lg:block">
    <SiteHeader variant="compact" />
  </div>
  <MobileNav title="Projects" items={projects.map((p) => ({ slug: p.slug, title: p.name }))} tocLabel="Projects" tocBase="/projects" barClass="-mt-8 sm:-mt-12" />

  <div class="space-y-8 px-5 sm:px-8 pb-12 pt-0">
    <div class="space-y-2">
      <h1 class="text-4xl font-semibold text-brand-text tracking-tight">Projects</h1>
      <p class="text-brand-text/70">CLI tools, AI experiments, and things that scratched an itch</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 border-t border-l border-solid border-brand-text/15">
      {projects.map((project, index) => (
        <a
          href={`/projects/${project.slug}`}
          class="group flex flex-col p-6 md:p-8 border-b border-r border-solid border-brand-text/15 hover:bg-brand-text/[0.015] dark:hover:bg-white/[0.02] transition-colors"
        >
          <div class="relative aspect-square mb-6 flex items-center justify-center overflow-hidden border border-solid border-brand-text/15 bg-brand-text/[0.015] dark:bg-white/[0.02] group-hover:border-brand-text/30 transition-colors">
            {(project.logo || project.mediaUrl) ? (
              <img src={project.logo || project.mediaUrl} alt={project.name} class="absolute inset-0 w-full h-full object-contain" loading="lazy" />
            ) : (
              <span class="font-pixel text-7xl md:text-8xl text-brand-text/[0.08] group-hover:text-[#0D3EFF]/25 dark:group-hover:text-[#FF5F1F]/30 transition-colors select-none">
                {String(index + 1).padStart(2, '0')}
              </span>
            )}
            <div class="absolute top-2 left-2 w-3 h-3 border-l-2 border-t-2 border-[#0D3EFF] dark:border-[#FF5F1F] opacity-0 group-hover:opacity-100 transition-opacity"></div>
            <div class="absolute bottom-2 right-2 w-3 h-3 border-r-2 border-b-2 border-[#0D3EFF] dark:border-[#FF5F1F] opacity-0 group-hover:opacity-100 transition-opacity"></div>
          </div>

          <time class="font-pixel text-[10px] uppercase tracking-wide text-brand-text/35 mb-2 block">
            {project.year}
          </time>
          <h2 class="text-xl md:text-2xl text-brand-text/90 group-hover:text-[#0D3EFF] dark:group-hover:text-[#FF5F1F] transition-colors leading-snug">
            {project.name}
          </h2>
          {project.description && (
            <p class="text-sm text-brand-text/55 mt-2.5 leading-relaxed line-clamp-3">{project.description}</p>
          )}

          <span class="font-pixel text-[10px] uppercase tracking-wide text-brand-text/30 group-hover:text-[#0D3EFF] dark:group-hover:text-[#FF5F1F] transition-colors mt-5 inline-flex items-center gap-1.5">
            View <span class="group-hover:translate-x-1 transition-transform">→</span>
          </span>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
