---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import MobileNav from '../../components/MobileNav.astro';
import Figure from '../../components/Figure.astro';
import { SITE_CONFIG } from '../../config';

export async function getStaticPaths() {
  const writingEntries = await getCollection('writing', ({ data }) => {
    return data.draft !== true;
  });
  return writingEntries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { slug } = Astro.params;
const allWriting = await getCollection('writing', ({ data }) => {
  return data.draft !== true;
});

let entry = Astro.props.entry ?? allWriting.find((piece) => piece.slug === slug);

if (!entry) {
  return Astro.redirect('/writing');
}

const { Content } = await entry.render();

const sortedWriting = allWriting.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const wordCount = entry.body.trim().split(/\s+/).filter(Boolean).length;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: entry.data.title,
  description: entry.data.description,
  datePublished: entry.data.date.toISOString(),
  author: {
    '@type': 'Person',
    name: 'Ankit Kumar',
    url: 'https://ankitkr.com',
  },
  url: Astro.url.href,
  publisher: {
    '@type': 'Person',
    name: 'Ankit Kumar',
    url: 'https://ankitkr.com',
  },
};
---

<BaseLayout title={entry.data.title} description={entry.data.description} image={entry.data.cover} schema={articleSchema} reader={true}>
  <div class="hidden lg:block">
    <SiteHeader variant="compact" />
  </div>

  <MobileNav title={entry.data.title} items={sortedWriting.map((p) => ({ slug: p.slug, title: p.data.title }))} currentSlug={entry.slug} />

  <div class="grid grid-cols-1 lg:grid-cols-12 lg:gap-0 lg:flex-1 lg:min-h-0 lg:overflow-hidden">
    <!-- Left: Table of Contents -->
    <aside class="hidden lg:block lg:col-span-2 lg:h-full lg:overflow-y-auto">
      <div class="pr-6 pt-1">
        <p class="font-pixel text-xs uppercase tracking-widest text-brand-text/50 mb-4">Writing</p>
        <ul class="space-y-2.5">
          {sortedWriting.map((piece, index) => (
            <li class="flex items-start gap-2 text-[15px] leading-snug">
              <span class="font-pixel text-xs text-brand-text/30 mt-1 shrink-0">{String(index + 1).padStart(2, '0')}</span>
              <a
                href={`/writing/${piece.slug}`}
                class={
                  piece.slug === entry.slug
                    ? 'text-[#0D3EFF] dark:text-[#FF5F1F]'
                    : 'text-brand-text/70 hover:text-brand-text transition-colors'
                }
              >
                {piece.data.title}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </aside>

    <!-- Center: Article -->
    <article id="paper-scroll" class="lg:col-span-9 paper-serif lg:px-8 lg:h-full lg:overflow-y-auto lg:pb-12">
      <div class="mx-auto rounded-sm p-8 md:bg-white md:shadow-[0px_1px_4px_1px_rgba(0,0,0,0.05),0px_1px_1px_0px_rgba(0,0,0,0.08)] dark:md:bg-[#141417] dark:md:shadow-none lg:px-16 lg:py-20">
        <!-- Title block -->
        <header class="text-center mb-12">
          <p class="font-pixel text-xs uppercase tracking-widest text-brand-text/50 mb-6">
            {wordCount.toLocaleString()} Words &nbsp;|&nbsp; {SITE_CONFIG.author.name}
          </p>
          <h1 class="text-4xl md:text-5xl text-brand-text leading-tight mb-6">
            {entry.data.title}
          </h1>
          <p class="text-lg md:text-xl text-brand-text/60 leading-relaxed max-w-xl mx-auto">
            {entry.data.description}
          </p>
          <p class="text-brand-text/30 tracking-[0.4em] mt-10 select-none">-----</p>
        </header>

        {entry.data.cover && (
          <figure class="not-prose mb-12 overflow-hidden border border-solid border-brand-text/10">
            <img
              src={entry.data.cover}
              alt={entry.data.title}
              class="w-full h-auto cursor-zoom-in"
              loading="eager"
              data-zoomable
            />
          </figure>
        )}

        <!-- Body -->
        <div class="prose max-w-none text-[17px]
          prose-headings:text-brand-text prose-headings:tracking-tight
          prose-h2:text-2xl prose-h2:mt-12 prose-h2:mb-4
          prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3
          prose-p:text-brand-text/90 prose-p:leading-[1.8] prose-p:mb-6
          prose-a:text-brand-text prose-a:underline prose-a:underline-offset-4 prose-a:decoration-brand-text/40 hover:prose-a:decoration-brand-text prose-a:transition-colors
          prose-strong:text-brand-text prose-strong:font-semibold
          prose-ul:my-6 prose-ul:space-y-2 prose-li:text-brand-text/90 prose-li:leading-[1.8]
          prose-ol:my-6 prose-ol:space-y-2
          prose-code:font-mono prose-code:text-brand-accent4 prose-code:bg-brand-accent4/10 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded-sm prose-code:text-sm prose-code:before:content-[''] prose-code:after:content-['']
          prose-pre:bg-brand-text/[0.04] prose-pre:text-brand-text/90 prose-pre:border prose-pre:border-solid prose-pre:border-brand-text/15 prose-pre:rounded-none prose-pre:p-5 prose-pre:text-[13px] prose-pre:leading-relaxed prose-pre:overflow-x-auto prose-pre:my-8
          prose-blockquote:border-l-2 prose-blockquote:border-brand-text/20 prose-blockquote:pl-6 prose-blockquote:py-1 prose-blockquote:my-8 prose-blockquote:italic prose-blockquote:text-brand-text/70
          prose-hr:border-t prose-hr:border-solid prose-hr:border-brand-text/15 prose-hr:my-12
          prose-img:border prose-img:border-solid prose-img:border-brand-text/10 prose-img:my-10 prose-img:mx-auto">
          <Content components={{ Figure }} />
        </div>
      </div>
    </article>

    <!-- Right: Reading progress rail -->
    <aside class="hidden lg:block lg:col-span-1 lg:h-full">
      <div class="flex flex-col items-end pl-2 pt-1">
        <span id="reading-progress" class="font-pixel text-xs text-[#0D3EFF] dark:text-[#FF5F1F] mb-4 tabular-nums">0.00</span>
        <div class="relative w-full h-[60vh] flex flex-col justify-between items-end font-pixel text-brand-text/15 text-[10px] leading-none overflow-hidden" aria-hidden="true">
          {Array.from({ length: 28 }).map(() => (
            <span>—</span>
          ))}
          <span id="progress-marker" class="absolute right-0 top-0 text-brand-text/70 dark:text-brand-text/80 transition-[top] duration-75">▶</span>
        </div>
      </div>
    </aside>
  </div>
</BaseLayout>

<script>
  const paper = document.getElementById('paper-scroll');

  function updateReadingProgress() {
    // On large screens the paper column scrolls internally; otherwise the page scrolls.
    const usePaper = paper && paper.scrollHeight > paper.clientHeight + 1;
    const el = usePaper ? paper : document.documentElement;
    const max = el.scrollHeight - el.clientHeight;
    const ratio = max > 0 ? Math.min(1, el.scrollTop / max) : 0;

    const label = document.getElementById('reading-progress');
    if (label) label.textContent = ratio.toFixed(2);

    const marker = document.getElementById('progress-marker');
    if (marker) marker.style.top = `calc(${ratio * 100}% - 0.5em)`;
  }

  updateReadingProgress();
  paper?.addEventListener('scroll', updateReadingProgress, { passive: true });
  window.addEventListener('scroll', updateReadingProgress, { passive: true });
  window.addEventListener('resize', updateReadingProgress);
</script>
