---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import MobileNav from '../../components/MobileNav.astro';

const allWriting = await getCollection('writing', ({ data }) => {
  return data.draft !== true;
});

const sortedWriting = allWriting.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

function formatDate(date: Date) {
  return new Date(date).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
}
---

<BaseLayout title="Writing" description="Essays and long-form thoughts">
  <SiteHeader variant="hero" />
  <MobileNav barless title="Ankit Kumar" items={sortedWriting.map((p) => ({ slug: p.slug, title: p.data.title }))} />

  <div class="paper-serif">
    <!-- Section header -->
    <header class="text-center mb-14">
      <p class="font-pixel text-sm uppercase tracking-widest text-brand-text/40">// Writing //</p>
    </header>

    <!-- Card grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 border-t border-l border-solid border-brand-text/15">
      {sortedWriting.map((piece, index) => (
        <a
          href={`/writing/${piece.slug}`}
          class="group flex flex-col p-6 md:p-8 border-b border-r border-solid border-brand-text/15 hover:bg-brand-text/[0.015] dark:hover:bg-white/[0.02] transition-colors"
        >
          <div class="relative aspect-[4/3] mb-6 flex items-center justify-center overflow-hidden border border-solid border-brand-text/15 bg-brand-text/[0.015] dark:bg-white/[0.02] group-hover:border-brand-text/30 transition-colors">
            {piece.data.cover ? (
              <img src={piece.data.cover} alt={piece.data.title} class="absolute inset-0 w-full h-full object-cover" loading="lazy" />
            ) : (
              <span class="font-pixel text-7xl md:text-8xl text-brand-text/[0.08] group-hover:text-[#0D3EFF]/25 dark:group-hover:text-[#FF5F1F]/30 transition-colors select-none">
                {String(index + 1).padStart(2, '0')}
              </span>
            )}
            <div class="absolute top-2 left-2 w-3 h-3 border-l-2 border-t-2 border-[#0D3EFF] dark:border-[#FF5F1F] opacity-0 group-hover:opacity-100 transition-opacity"></div>
            <div class="absolute bottom-2 right-2 w-3 h-3 border-r-2 border-b-2 border-[#0D3EFF] dark:border-[#FF5F1F] opacity-0 group-hover:opacity-100 transition-opacity"></div>
          </div>

          <time class="font-pixel text-[10px] uppercase tracking-wide text-brand-text/35 mb-2 block">
            {formatDate(piece.data.date)}
          </time>
          <h2 class="text-xl md:text-2xl text-brand-text/90 group-hover:text-[#0D3EFF] dark:group-hover:text-[#FF5F1F] transition-colors leading-snug">
            {piece.data.title}
          </h2>
          {piece.data.description && (
            <p class="text-sm text-brand-text/55 mt-2.5 leading-relaxed">{piece.data.description}</p>
          )}

          <span class="font-pixel text-[10px] uppercase tracking-wide text-brand-text/30 group-hover:text-[#0D3EFF] dark:group-hover:text-[#FF5F1F] transition-colors mt-5 inline-flex items-center gap-1.5">
            Read <span class="group-hover:translate-x-1 transition-transform">→</span>
          </span>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
