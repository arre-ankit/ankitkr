---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const allWriting = await getCollection('writing', ({ data }) => {
  return data.draft !== true;
});

const sortedWriting = allWriting.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

function formatDate(date: Date) {
  return new Date(date).toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
}
---

<BaseLayout title="Writing" description="Essays and long-form thoughts">
  <div class="space-y-12">
    <div>
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 dark:text-gray-100 mb-4">Writing</h1>
      <p class="text-lg text-gray-600 dark:text-gray-400">Essays and long-form thoughts</p>
    </div>

    <div class="space-y-8">
      {sortedWriting.map((piece) => (
        <article class="group">
          <a href={`/writing/${piece.slug}`} class="block space-y-2">
            <time class="text-sm text-gray-500 dark:text-gray-500 font-mono">
              {formatDate(piece.data.date)}
            </time>
            <h2 class="text-xl md:text-2xl font-semibold text-gray-900 dark:text-gray-100 group-hover:text-gray-600 dark:group-hover:text-gray-400 transition-colors">
              {piece.data.title}
            </h2>
            <p class="text-gray-600 dark:text-gray-400 leading-relaxed">
              {piece.data.description}
            </p>
          </a>
        </article>
      ))}
    </div>

    {sortedWriting.length === 0 && (
      <p class="text-gray-600 dark:text-gray-400">No writing yet. Check back soon!</p>
    )}
  </div>
</BaseLayout>
